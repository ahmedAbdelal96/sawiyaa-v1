# Sawiyaa backend production example
# Copy this file to your deployment secret store or keep it as the source of truth for production envs.

# Core app/runtime
APP_ENV=production
NODE_ENV=production
PORT=7000
APP_NAME=sawiyaa-backend-v1
APP_URL=https://sawiyaa.com
APP_BASE_URL=https://sawiyaa.com
APP_DEFAULT_LOCALE=ar
CORS_ORIGINS=https://sawiyaa.com
CONFIG_HTTP_ENABLED=false
CONFIG_HTTP_TOKEN=
LOG_LEVEL=info
LOG_PRETTY=false
LOG_HTTP_ENABLED=true

# Throttling / Rate limit store
THROTTLE_STORE=memory
THROTTLE_KEY_PREFIX=sawiyaa:throttle
THROTTLE_KEY_HASH_SECRET=

# Step-up / re-auth
STEP_UP_ENABLED=true
STEP_UP_TTL_SECONDS=600

# Database
DATABASE_URL=postgresql://sawiyaa:<change-me>@postgres:5432/sawiyaa?schema=public

# JWT
JWT_ACCESS_SECRET=<change-me>
JWT_REFRESH_SECRET=<change-me>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=sawiyaa-backend-v1
AUTH_PASSWORD_SALT_ROUNDS=12
AUTH_OTP_CODE_LENGTH=6
AUTH_LOGIN_OTP_TTL_MINUTES=10
AUTH_RESET_PASSWORD_TTL_MINUTES=15
AUTH_OTP_MAX_ATTEMPTS=5
AUTH_OTP_RESEND_COOLDOWN_SECONDS=30
AUTH_COOKIE_AUTH_ENABLED=false
AUTH_CSRF_ENFORCEMENT_ENABLED=false
AUTH_CSRF_COOKIE_NAME=sawiyaa_csrf_token
AUTH_CSRF_HEADER_NAME=x-csrf-token
AUTH_PRACTITIONER_LOGIN_OTP_ENABLED=true
AUTH_PRACTITIONER_LOGIN_OTP_BYPASS_IN_DEV=false

# Google Auth
GOOGLE_CLIENT_ID=<change-me>
GOOGLE_CLIENT_SECRET=<change-me>
GOOGLE_CALLBACK_URL=https://sawiyaa.com/api/v1/auth/google/callback

# Email / SMS
MAIL_PROVIDER=smtp
MAIL_FROM=noreply@sawiyaa.com
MAIL_HOST=<change-me>
MAIL_PORT=587
MAIL_USER=<change-me>
MAIL_PASS=<change-me>
MAIL_SECURE=false
DEV_OTP_EMAIL_REDIRECT=
DEV_OTP_BYPASS_DELIVERY_FAILURES=false
BREVO_API_KEY=
BREVO_API_URL=https://api.brevo.com
SMS_PROVIDER=twilio

# Video
VIDEO_PROVIDER_DEFAULT=DAILY
DAILY_API_KEY=<change-me>
DAILY_API_BASE_URL=https://api.daily.co/v1
DAILY_WEBHOOK_SECRET=<change-me>

# Session booking
SESSION_PAYMENT_RESERVATION_MINUTES=15
SESSION_RUNTIME_PREPARE_LEAD_MINUTES=1440

# Payment redirect URLs
PAYMENT_SUCCESS_URL=https://sawiyaa.com/payment/success
PAYMENT_FAILED_URL=https://sawiyaa.com/payment/failed
PAYMENT_PENDING_URL=https://sawiyaa.com/payment/pending

# Payments - Stripe
PAYMENT_STRIPE_ENABLED=false
STRIPE_MODE=test
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_BASE_URL=https://api.stripe.com

# Payments - Paymob
PAYMENT_PAYMOB_ENABLED=false
PAYMOB_MODE=test
PAYMOB_API_KEY=
PAYMOB_PUBLIC_KEY=
PAYMOB_HMAC_SECRET=
PAYMOB_EGP_CARD_INTEGRATION_ID=
PAYMOB_EGP_WALLET_INTEGRATION_ID=
PAYMOB_USD_CARD_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
PAYMOB_DEFAULT_CHECKOUT_METHOD=CARD
PAYMOB_BASE_URL=https://accept.paymob.com/api
PAYMOB_INTENTION_BASE_URL=https://flashapi.paymob.com
PAYMOB_CHECKOUT_BASE_URL=https://flashapi.paymob.com
PAYMOB_CHECKOUT_FLOW=legacy
PAYMOB_METHOD_REGISTRY_JSON=
PAYMOB_INTEGRATION_ID=
PAYMOB_INTEGRATION_ID_CARD=
PAYMOB_INTEGRATION_ID_WALLET=

# Finance
FINANCE_VAT_ENABLED=false
FINANCE_VAT_RATE_PERCENT=0
FINANCE_GATEWAY_FEE_RATE_PERCENT=0
FINANCE_GATEWAY_FEE_FIXED_AMOUNT=0

# Corporate sponsorship
CORPORATE_CODE_PEPPER=<change-me-to-a-long-random-secret>
