  status     ArticleStatus     @default(DRAFT)
  visibility ArticleVisibility @default(PUBLIC)

  coverImageUrl         String? @db.VarChar(500)
  featuredImageAlt      String? @db.VarChar(191)
  currentRevisionNumber Int     @default(1)

  lastSubmittedAt    DateTime?
  approvedAt         DateTime?
  rejectedAt         DateTime?
  publishedAt        DateTime?
  scheduledPublishAt DateTime?
  archivedAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorUser         User                 @relation("ArticleAuthorUser", fields: [authorUserId], references: [id], onDelete: Restrict)
  authorPractitioner PractitionerProfile? @relation("ArticleAuthorPractitioner", fields: [authorPractitionerId], references: [id], onDelete: SetNull)
  primaryCategory    ArticleCategory?     @relation("ArticlePrimaryCategory", fields: [primaryCategoryId], references: [id], onDelete: SetNull)

  translations        ArticleTranslation[]
  categoryAssignments ArticleCategoryAssignment[]
  reviews             ArticleReview[]
  moderationLogs      ArticleModerationLog[]
  tagAssignments      ArticleTagAssignment[]

  @@index([status, publishedAt])
  @@index([primaryCategoryId, status, publishedAt])
  @@index([authorUserId, status])
  @@index([authorPractitionerId, status])
  @@index([visibility, status, publishedAt])
  @@index([scheduledPublishAt])
  @@index([approvedAt])
}

model ArticleTranslation {
  id                 String        @id @default(uuid()) @db.Uuid
