model AcademyProgramSessionAttendance {
  id                        String                              @id @default(uuid()) @db.Uuid
  academyProgramSessionId    String                              @db.Uuid
  academyProgramEnrollmentId  String                              @db.Uuid
  attendanceStatus           AcademyProgramSessionAttendanceStatus
  markedByUserId             String?                             @db.Uuid
  markedAt                   DateTime                            @default(now())
  createdAt                  DateTime                            @default(now())
  updatedAt                  DateTime                            @updatedAt

  academyProgramSession     AcademyProgramSession               @relation(fields: [academyProgramSessionId], references: [id], onDelete: Cascade)
  academyProgramEnrollment  AcademyProgramEnrollment            @relation(fields: [academyProgramEnrollmentId], references: [id], onDelete: Cascade)
  markedByUser              User?                               @relation("AcademyProgramSessionAttendanceMarkedByUser", fields: [markedByUserId], references: [id], onDelete: SetNull)

  @@unique([academyProgramSessionId, academyProgramEnrollmentId])
  @@index([academyProgramSessionId, attendanceStatus])
  @@index([academyProgramEnrollmentId, attendanceStatus])
  @@index([markedByUserId, markedAt])
}

model AcademyProgramPaymentAttempt {
  id                         String   @id @default(uuid()) @db.Uuid
  academyProgramId           String   @db.Uuid
  academyProgramEnrollmentId String   @db.Uuid
  paymentId                  String?  @unique @db.Uuid
  provider                   PaymentProvider
  status                     PaymentStatus
  amountSubtotal             Decimal  @db.Decimal(18, 2)
  amountDiscount             Decimal  @default(0) @db.Decimal(18, 2)
  amountTotal                Decimal  @db.Decimal(18, 2)
  currencyCode               String   @db.VarChar(3)
  providerPaymentRef         String?  @db.VarChar(191)
  providerOrderRef           String?  @db.VarChar(191)
  providerCustomerRef        String?  @db.VarChar(191)
  checkoutUrl                String?  @db.VarChar(500)
  clientSecret               String?  @db.VarChar(500)
  failureReason              String?  @db.VarChar(500)
  expiresAt                  DateTime?
  confirmedAt                DateTime?
  failedAt                   DateTime?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  academyProgram         AcademyProgram          @relation(fields: [academyProgramId], references: [id], onDelete: Cascade)
  academyProgramEnrollment AcademyProgramEnrollment @relation(fields: [academyProgramEnrollmentId], references: [id], onDelete: Cascade)
  payment                Payment?               @relation("AcademyProgramPaymentAttemptPayment", fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([academyProgramId, status, createdAt])
  @@index([academyProgramEnrollmentId, createdAt])
  @@index([providerPaymentRef])
}

//////////////////////////////
// Security Audit
//////////////////////////////

enum SecurityAuditOutcome {
  SUCCESS
  FAILURE
  DENIED
}

enum SecurityAuditActorType {
  USER
  SYSTEM
  SCHEDULED_JOB
  PAYMENT_WEBHOOK
  MIGRATION
  SEED_QA
}

/// Platform-level security audit log.
/// Separate from AuditEvent (notification delivery domain).
/// Critical writes use the caller transaction; operational writes may remain best-effort.
/// Never log: raw JWTs, passwords, OTP codes, refresh tokens, or secrets.
model SecurityAuditLog {
  id             String               @id @default(uuid()) @db.Uuid
  action         String               @db.VarChar(120)
  outcome        SecurityAuditOutcome
  actorType      SecurityAuditActorType?
  actorUserId    String?              @db.Uuid
  actorRolesJson Json?
  source         String?              @db.VarChar(50)
  resourceType   String?              @db.VarChar(100)
  resourceId     String?              @db.VarChar(191)
  targetUserId   String?              @db.Uuid
  ipAddress      String?              @db.VarChar(64)
  userAgent      String?              @db.VarChar(500)
  requestId      String?              @db.VarChar(191)
  correlationId  String?              @db.VarChar(191)
  reason         String?              @db.VarChar(500)
  metadataJson   Json?
  occurredAt     DateTime             @default(now())

  actorUser User? @relation("SecurityAuditLogActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([action, occurredAt])
  @@index([actorUserId, occurredAt])
  @@index([requestId, occurredAt])
  @@index([outcome, occurredAt])
  @@index([resourceType, resourceId])
  @@index([occurredAt])
}

//////////////////////////////
// Corporate Voucher Sponsorship
//////////////////////////////

model CorporateOrganization {
  id             String                      @id @default(uuid()) @db.Uuid
  name           String                      @db.VarChar(255)
  companyCode    String                      @unique @db.VarChar(50)
  countryIsoCode String?                     @db.VarChar(3)
  status         CorporateOrganizationStatus @default(ACTIVE)
  billingEmail   String                      @db.VarChar(255)
  contactName    String?                     @db.VarChar(255)
  contactPhone   String?                     @db.VarChar(50)
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt

  contracts    CorporateContract[]
  batches      CorporateCodeBatch[]
  codes        CorporateBenefitCode[]
  ledger       CorporateLedger[]
  sponsorships CorporateSessionSponsorship[]

  @@index([status])
}

model CorporateContract {
  id             String                  @id @default(uuid()) @db.Uuid
  organizationId String                  @db.Uuid
  startDate      DateTime
  endDate        DateTime
  status         CorporateContractStatus @default(DRAFT)
  billingMode    CorporateBillingMode
  currency       String                  @db.VarChar(3)
  market         CorporateMarket
  notes          Json?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  organization CorporateOrganization         @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  plans        CorporateBenefitPlan[]
  batches      CorporateCodeBatch[]
  codes        CorporateBenefitCode[]
  ledger       CorporateLedger[]
  sponsorships CorporateSessionSponsorship[]

  @@index([organizationId, status])
  @@index([status, endDate])
}

model CorporateBenefitPlan {
  id                        String                     @id @default(uuid()) @db.Uuid
  contractId                String                     @db.Uuid
  name                      String                     @db.VarChar(255)
  coverageType              CorporateCoverageType
  coveragePercent           Int?
  maxCoverageAmount         Decimal?                   @db.Decimal(12, 2)
  maxTotalCoverage          Decimal?                   @db.Decimal(14, 2)
  currency                  String                     @db.VarChar(3)
  codeUsageLimit            Int                        @default(1)
  codeReservationTtlMinutes Int                        @default(15)
  status                    CorporateBenefitPlanStatus @default(ACTIVE)
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt

  contract      CorporateContract                  @relation(fields: [contractId], references: [id], onDelete: Restrict)
  specialties   CorporateBenefitPlanSpecialty[]
  practitioners CorporateBenefitPlanPractitioner[]
  batches       CorporateCodeBatch[]
  codes         CorporateBenefitCode[]
  sponsorships  CorporateSessionSponsorship[]

  @@index([contractId, status])
}

model CorporateBenefitPlanSpecialty {
  id          String @id @default(uuid()) @db.Uuid
  planId      String @db.Uuid
  specialtyId String @db.Uuid

  plan      CorporateBenefitPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  specialty Specialty            @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  @@unique([planId, specialtyId])
  @@index([specialtyId])
}

model CorporateBenefitPlanPractitioner {
  id             String @id @default(uuid()) @db.Uuid
  planId         String @db.Uuid
  practitionerId String @db.Uuid

  plan         CorporateBenefitPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  practitioner PractitionerProfile  @relation(fields: [practitionerId], references: [id], onDelete: Cascade)

  @@unique([planId, practitionerId])
  @@index([practitionerId])
}

model CorporateCodeBatch {
  id                String               @id @default(uuid()) @db.Uuid
  organizationId    String               @db.Uuid
  contractId        String               @db.Uuid
  benefitPlanId     String               @db.Uuid
  name              String               @db.VarChar(255)
  totalCodes        Int
  generatedCount    Int                  @default(0)
  expiresAt         DateTime?
  status            CorporateBatchStatus @default(GENERATING)
  createdByAdminId  String               @db.Uuid
  exportedAt        DateTime?
  exportedByAdminId String?              @db.Uuid
  revokedAt         DateTime?
  revokedByAdminId  String?              @db.Uuid
  revokeReason      String?              @db.VarChar(500)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  organization CorporateOrganization  @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  contract     CorporateContract      @relation(fields: [contractId], references: [id], onDelete: Restrict)
  benefitPlan  CorporateBenefitPlan   @relation(fields: [benefitPlanId], references: [id], onDelete: Restrict)
  codes        CorporateBenefitCode[]

  @@index([organizationId, status])
  @@index([contractId, status])
  @@index([benefitPlanId, status])
}

model CorporateBenefitCode {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @db.Uuid
  contractId     String @db.Uuid
  benefitPlanId  String @db.Uuid
  batchId        String @db.Uuid

  codeHash      String @unique @db.VarChar(64)
  codePrefix    String @db.VarChar(8)
  codeLast4     String @db.VarChar(4)
  pepperVersion Int    @default(1)

  status     CorporateCodeStatus @default(AVAILABLE)
  usageLimit Int                 @default(1)
  usedCount  Int                 @default(0)

  reservedByUserId  String?   @db.Uuid
  reservedSessionId String?   @db.Uuid
  reservedUntil     DateTime?

  usedByUserId  String?   @db.Uuid
  usedSessionId String?   @db.Uuid
  usedAt        DateTime?

  expiresAt        DateTime?
  revokedAt        DateTime?
  revokedByAdminId String?   @db.Uuid
  revokeReason     String?   @db.VarChar(500)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organization CorporateOrganization         @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  contract     CorporateContract             @relation(fields: [contractId], references: [id], onDelete: Restrict)
  benefitPlan  CorporateBenefitPlan          @relation(fields: [benefitPlanId], references: [id], onDelete: Restrict)
  batch        CorporateCodeBatch            @relation(fields: [batchId], references: [id], onDelete: Restrict)
  sponsorships CorporateSessionSponsorship[]
  ledger       CorporateLedger[]

  @@index([organizationId, status])
  @@index([batchId, status])
  @@index([status, expiresAt])
  @@index([status, reservedUntil])
  @@index([reservedUntil])
  @@index([usedByUserId])
  @@index([usedSessionId])
  @@index([reservedSessionId])
  @@index([organizationId, createdAt])
  @@index([benefitPlanId, status])
}

model CorporateSessionSponsorship {
  id             String @id @default(uuid()) @db.Uuid
  sessionId      String @unique @db.Uuid
  organizationId String @db.Uuid
  contractId     String @db.Uuid
  benefitPlanId  String @db.Uuid
  codeId         String @db.Uuid

  coverageType     CorporateCoverageType
  billingMode      CorporateBillingMode
  market           CorporateMarket?
  originalAmount   Decimal               @db.Decimal(12, 2)
  coveredAmount    Decimal               @db.Decimal(12, 2)
  patientPayAmount Decimal               @db.Decimal(12, 2)
  currency         String                @db.VarChar(3)

  snapshotJson Json
  status       CorporateSponsorshipStatus @default(RESERVED)
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt

  organization  CorporateOrganization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  contract      CorporateContract     @relation(fields: [contractId], references: [id], onDelete: Restrict)
  benefitPlan   CorporateBenefitPlan  @relation(fields: [benefitPlanId], references: [id], onDelete: Restrict)
  code          CorporateBenefitCode  @relation(fields: [codeId], references: [id], onDelete: Restrict)
  session       Session               @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  ledgerEntries CorporateLedger[]

  @@index([organizationId, createdAt])
  @@index([contractId, createdAt])
  @@index([benefitPlanId, status])
  @@index([status, createdAt])
  @@index([codeId])
}

model CorporateLedger {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String  @db.Uuid
  contractId     String? @db.Uuid
  sessionId      String? @db.Uuid
  codeId         String? @db.Uuid
  sponsorshipId  String? @db.Uuid

  eventType CorporateLedgerEventType
  amount    Decimal?                 @db.Decimal(14, 2)
  currency  String?                  @db.VarChar(3)
  quantity  Int?

  metadata  Json?
  createdAt DateTime @default(now())

  organization CorporateOrganization        @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  contract     CorporateContract?           @relation(fields: [contractId], references: [id], onDelete: SetNull)
  session      Session?                     @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  code         CorporateBenefitCode?        @relation(fields: [codeId], references: [id], onDelete: SetNull)
  sponsorship  CorporateSessionSponsorship? @relation(fields: [sponsorshipId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([contractId, createdAt])
  @@index([sessionId])
  @@index([codeId])
  @@index([sponsorshipId])
  @@index([organizationId, eventType, createdAt])
}
