model ArticleCategory {
  id              String   @id @default(uuid()) @db.Uuid
  parentId        String?  @db.Uuid
  slugRoot        String   @unique @db.VarChar(191)
  sortOrder       Int      @default(0)
  isActive        Boolean  @default(true)
  isFeatured      Boolean  @default(false)
  createdByUserId String?  @db.Uuid
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  parent          ArticleCategory?             @relation("ArticleCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children        ArticleCategory[]            @relation("ArticleCategoryTree")
  translations    ArticleCategoryTranslation[]
  primaryArticles Article[]                    @relation("ArticlePrimaryCategory")
  assignments     ArticleCategoryAssignment[]

  @@index([isActive, sortOrder])
  @@index([parentId, sortOrder])
}

model ArticleCategoryTranslation {
  id                String        @id @default(uuid()) @db.Uuid
  articleCategoryId String        @db.Uuid
  locale            ContentLocale
  title             String        @db.VarChar(191)
  description       String?       @db.VarChar(500)
  slug              String        @db.VarChar(191)
  metaTitle         String?       @db.VarChar(191)
  metaDescription   String?       @db.VarChar(300)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  articleCategory ArticleCategory @relation(fields: [articleCategoryId], references: [id], onDelete: Cascade)

  @@unique([locale, slug])
  @@unique([articleCategoryId, locale])
  @@index([locale, title])
}

model Article {
  id                   String  @id @default(uuid()) @db.Uuid
  authorUserId         String  @db.Uuid
  authorPractitionerId String? @db.Uuid
