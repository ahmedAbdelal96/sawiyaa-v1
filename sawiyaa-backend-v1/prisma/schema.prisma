  referenceId   String?                      @db.VarChar(191)
  metadataJson  Json?
  actorType     SecurityAuditActorType?
  actorUserId   String?                       @db.Uuid
  actorRolesJson Json?
  source        String?                       @db.VarChar(50)
  reason        String?                       @db.VarChar(500)
  requestId     String?                       @db.VarChar(191)
  correlationId String?                       @db.VarChar(191)
  externalReference String?                   @db.VarChar(191)
  idempotencyKey String?                      @db.VarChar(191)
  occurredAt    DateTime                      @default(now())
  effectiveAt   DateTime                     @default(now())

