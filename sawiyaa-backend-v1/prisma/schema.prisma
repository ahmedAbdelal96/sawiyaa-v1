//////////////////////////////
// Chat / Support / Moderation
//////////////////////////////

model Conversation {
  id               String             @id @default(uuid()) @db.Uuid
  conversationType ConversationType
  status           ConversationStatus @default(OPEN)

  patientId             String? @db.Uuid
  practitionerId        String? @db.Uuid
  supportTicketId       String? @unique @db.Uuid
  sessionId             String? @db.Uuid
  chatApprovalRequestId String? @unique @db.Uuid

  conversationRef String? @unique @db.VarChar(64)

  startedAt                           DateTime  @default(now())
  closedAt                            DateTime?
  adminSendingDisabledAt              DateTime?
  adminSendingDisabledByUserId        String?   @db.Uuid
  adminSendingDisabledReason          String?   @db.VarChar(500)
  adminSendingEnabledAt               DateTime?
  adminSendingEnabledByUserId         String?   @db.Uuid
  practitionerSendingDisabledAt       DateTime?
  practitionerSendingDisabledByUserId String?   @db.Uuid
  practitionerSendingDisabledReason   String?   @db.VarChar(500)
  practitionerSendingEnabledAt        DateTime?
  practitionerSendingEnabledByUserId  String?   @db.Uuid
  expiresAt                           DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient      PatientProfile?      @relation("ConversationPatient", fields: [patientId], references: [id], onDelete: SetNull)
  practitioner PractitionerProfile? @relation("ConversationPractitioner", fields: [practitionerId], references: [id], onDelete: SetNull)
  session      Session?             @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  participants        ConversationParticipant[]
  messages            Message[]
  internalNotes       InternalConversationNote[]
  moderationReports   ChatModerationReport[]
  moderationActions   ChatModerationAction[]
  supportTicket       SupportTicket?
  chatApprovalRequest ChatApprovalRequest?

  @@index([conversationType, status, startedAt])
  @@index([conversationType, status, updatedAt])
  @@index([patientId, status])
  @@index([practitionerId, status])
  @@index([supportTicketId])
  @@index([chatApprovalRequestId])
  @@index([sessionId])
}

model ConversationParticipant {
  id                String                      @id @default(uuid()) @db.Uuid
  conversationId    String                      @db.Uuid
  userId            String                      @db.Uuid
  participantRole   ConversationParticipantRole
  joinedAt          DateTime                    @default(now())
  leftAt            DateTime?
  lastReadMessageId String?                     @db.Uuid
  lastReadAt        DateTime?
  isMuted           Boolean                     @default(false)
  isActive          Boolean                     @default(true)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId, isActive])
  @@index([conversationId, participantRole])
}

model Message {
  id             String            @id @default(uuid()) @db.Uuid
  conversationId String            @db.Uuid
  senderUserId   String?           @db.Uuid
  messageType    MessageType       @default(TEXT)
  status         MessageStatus     @default(SENT)
  visibility     MessageVisibility @default(NORMAL)

  contentText      String?
  replyToMessageId String? @db.Uuid
  clientMessageId  String? @db.VarChar(191)
  clientMessagePayloadHash String? @db.Char(64)

  sentAt      DateTime  @default(now())
  deliveredAt DateTime?
  readAt      DateTime?
  editedAt    DateTime?
  deletedAt   DateTime?
  isFlagged   Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversation      Conversation           @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  replyToMessage    Message?               @relation("MessageReplies", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies           Message[]              @relation("MessageReplies")
  attachments       MessageAttachment[]
  moderationReports ChatModerationReport[]
  moderationActions ChatModerationAction[]

  @@index([conversationId, sentAt])
  @@index([conversationId, senderUserId, clientMessageId])
  @@index([senderUserId, sentAt])
  @@index([replyToMessageId])
  @@index([status, sentAt])
  @@index([isFlagged, sentAt])
}

model MessageAttachment {
  id              String   @id @default(uuid()) @db.Uuid
  messageId       String   @db.Uuid
  fileUrl         String   @db.VarChar(500)
  mimeType        String   @db.VarChar(191)
  fileSize        Int?
  originalName    String?  @db.VarChar(191)
  storageProvider String?  @db.VarChar(100)
  uploadedAt      DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model SupportTicket {
  id             String                      @id @default(uuid()) @db.Uuid
  openedByUserId String                      @db.Uuid
  createdByRole  ConversationParticipantRole
  patientId      String?                     @db.Uuid
  practitionerId String?                     @db.Uuid
  conversationId String                      @unique @db.Uuid

  ticketType SupportTicketType
  status     SupportTicketStatus   @default(OPEN)
  priority   SupportTicketPriority @default(MEDIUM)

  subject                        String    @db.VarChar(191)
  description                    String?   @db.VarChar(2000)
