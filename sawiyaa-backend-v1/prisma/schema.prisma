  academyProgram AcademyProgram @relation(fields: [academyProgramId], references: [id], onDelete: Restrict)
  academyLearner  AcademyLearner @relation(fields: [academyLearnerId], references: [id], onDelete: Restrict)
  user            User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  certificateUploadedByUser User? @relation("AcademyProgramEnrollmentCertificateUploadedByUser", fields: [certificateUploadedByUserId], references: [id], onDelete: SetNull)
  payment         Payment?       @relation("AcademyProgramEnrollmentPayment", fields: [paymentId], references: [id], onDelete: SetNull)
  paymentAttempts AcademyProgramPaymentAttempt[]
  attendanceRecords AcademyProgramSessionAttendance[]

  @@unique([academyProgramId, academyLearnerId])
  @@index([academyProgramId, status, registeredAt])
  @@index([academyProgramId, seatReservationExpiresAt])
  @@index([academyLearnerId, status])
  @@index([userId, status])
  @@index([paymentStatus])
  @@index([paymentId])
