model PackagePlan {
  id              String    @id @default(uuid()) @db.Uuid
  code            String    @unique @db.VarChar(100)
  sessionCount    Int
  discountPercent Decimal   @db.Decimal(5, 2)
  isActive        Boolean   @default(true)
  sortOrder       Int       @default(0)
  title           String    @db.VarChar(191)
  description     String?   @db.VarChar(1000)
  archivedAt      DateTime?
  metadataJson    Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  purchases PatientPackagePurchase[]

  @@index([isActive, sortOrder])
  @@index([archivedAt, isActive])
  @@index([sessionCount, discountPercent])
}

model RefundPolicy {
  id              String           @id @default(uuid()) @db.Uuid
  policyType      RefundPolicyType @unique
  key             String           @unique @db.VarChar(191)
  isPublic        Boolean          @default(true)
  titleAr         String?          @db.VarChar(500)
  titleEn         String?          @db.VarChar(500)
  isActive        Boolean          @default(true)
  activeVersionId String?          @unique @db.Uuid
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  activeVersion RefundPolicyVersion?     @relation("RefundPolicyActiveVersion", fields: [activeVersionId], references: [id], onDelete: SetNull)
  clauses       RefundPolicyClause[]
  acceptances   RefundPolicyAcceptance[]
  versions      RefundPolicyVersion[]
}

model RefundPolicyClause {
  id        String   @id @default(uuid()) @db.Uuid
  policyId  String   @db.Uuid
  titleAr   String?  @db.VarChar(1000)
  titleEn   String?  @db.VarChar(1000)
  bodyAr    String   @db.VarChar(4000)
  bodyEn    String   @db.VarChar(4000)
  sortOrder Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  policy RefundPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@index([policyId, sortOrder])
  @@index([policyId, isActive, sortOrder])
}

model RefundPolicyVersion {
  id                   String                    @id @default(uuid()) @db.Uuid
  refundPolicyId       String                    @db.Uuid
  versionNumber        Int
  titleByLocaleJson    Json
  summaryByLocaleJson  Json
  localizedContentJson Json
  clausesJson          Json
  rulesJson            Json
  contentHash          String                    @db.VarChar(64)
  status               RefundPolicyVersionStatus @default(DRAFT)
  effectiveFrom        DateTime?
  publishedAt          DateTime?
  publishedByAdminId   String?                   @db.Uuid
  archivedAt           DateTime?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  policy      RefundPolicy             @relation(fields: [refundPolicyId], references: [id], onDelete: Cascade)
  activeFor   RefundPolicy?            @relation("RefundPolicyActiveVersion")
  acceptances RefundPolicyAcceptance[]

  @@unique([refundPolicyId, versionNumber])
  @@index([refundPolicyId, status, versionNumber])
  @@index([refundPolicyId, publishedAt])
}

model RefundPolicyAcceptance {
  id                          String            @id @default(uuid()) @db.Uuid
  policyId                    String            @db.Uuid
  refundPolicyVersionId       String?           @db.Uuid
  refundPolicyType            RefundPolicyType
  acceptedAt                  DateTime          @default(now())
  acceptedByUserId            String            @db.Uuid
  paymentId                   String?           @unique @db.Uuid
  sessionId                   String?           @db.Uuid
  packagePurchaseId           String?           @db.Uuid
  policyVersionNumberSnapshot Int
  policyTypeSnapshot          RefundPolicyType?
  policyTitleArSnapshot       String?           @db.VarChar(500)
  policyTitleEnSnapshot       String?           @db.VarChar(500)
  policyTitleSnapshotJson     Json
  policySummarySnapshotJson   Json
  clausesSnapshotJson         Json
  rulesSnapshotJson           Json
  contentHashSnapshot         String            @db.VarChar(64)
  displayLocale               String            @db.VarChar(20)
  userAgent                   String?           @db.VarChar(500)
  ipAddress                   String?           @db.VarChar(100)
  consentTextHash             String?           @db.VarChar(64)
  metadataJson                Json?
  createdAt                   DateTime          @default(now())

  refundPolicy        RefundPolicy         @relation(fields: [policyId], references: [id], onDelete: Restrict)
  refundPolicyVersion RefundPolicyVersion? @relation(fields: [refundPolicyVersionId], references: [id], onDelete: SetNull)
  acceptedByUser      User                 @relation(fields: [acceptedByUserId], references: [id], onDelete: Restrict)

  @@index([policyId, acceptedAt])
  @@index([refundPolicyVersionId, acceptedAt])
  @@index([refundPolicyType, acceptedAt])
  @@index([paymentId])
  @@index([sessionId])
  @@index([packagePurchaseId])
}

