  countryCodeDeclared String? @db.VarChar(10)
  countryCodeSource   String? @db.VarChar(30)
  countryCodeMismatch Boolean @default(false)
  sourceLabel         String? @db.VarChar(191)
  city                String? @db.VarChar(191)
  jobTitle            String? @db.VarChar(191)
  employer            String? @db.VarChar(191)
  education           String? @db.VarChar(191)
  notes               String? @db.VarChar(1000)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  academyProgramEnrollments AcademyProgramEnrollment[]

  @@index([fullName])
  @@index([sourceLabel])
}

model AcademyProgram {
  id               String                 @id @default(uuid()) @db.Uuid
  slug             String                 @unique @db.VarChar(191)
  titleAr          String                 @db.VarChar(191)
  titleEn          String                 @db.VarChar(191)
  descriptionAr    String?
  descriptionEn    String?
  coverImageUrl    String?                @db.VarChar(500)
  categoryId       String?                @db.Uuid
  priceEgp         Decimal?               @db.Decimal(18, 2)
  priceUsd         Decimal?               @db.Decimal(18, 2)
  registrationOpen Boolean                @default(false)
  maxSeats         Int?
  startAt          DateTime?
  endAt            DateTime?
  status           AcademyProgramStatus   @default(DRAFT)
  createdByUserId  String?                @db.Uuid
  publishedAt      DateTime?
  archivedAt       DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  category     CourseCategory?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdByUser User?                  @relation("AcademyProgramCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)
  sessions     AcademyProgramSession[]
  enrollments  AcademyProgramEnrollment[]
  paymentAttempts AcademyProgramPaymentAttempt[]

  @@index([status, publishedAt])
  @@index([categoryId, status])
  @@index([registrationOpen, status])
  @@index([startAt, endAt])
  @@index([createdByUserId, createdAt])
}

model AcademyProgramSession {
  id                    String                     @id @default(uuid()) @db.Uuid
  academyProgramId      String                     @db.Uuid
  titleAr               String                     @db.VarChar(191)
  titleEn               String                     @db.VarChar(191)
  descriptionAr         String?
  descriptionEn         String?
  startsAt              DateTime
  endsAt                DateTime
  deliveryMethod        AcademyProgramDeliveryMethod
  internalDeliveryNote  String?
  internalDeliveryLink  String?                    @db.VarChar(500)
  sortOrder             Int                        @default(0)
  isPublished           Boolean                    @default(false)
  publishedAt           DateTime?
  createdByUserId       String?                    @db.Uuid
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt

  academyProgram AcademyProgram @relation(fields: [academyProgramId], references: [id], onDelete: Cascade)
  createdByUser   User?         @relation("AcademyProgramSessionCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)
  attendanceRecords AcademyProgramSessionAttendance[]

  @@index([academyProgramId, sortOrder])
  @@index([academyProgramId, startsAt])
  @@index([isPublished, startsAt])
  @@index([createdByUserId, createdAt])
}

model AcademyProgramEnrollment {
  id                        String                         @id @default(uuid()) @db.Uuid
  academyProgramId          String                         @db.Uuid
  academyLearnerId          String                         @db.Uuid
  userId                    String?                        @db.Uuid
  publicAccessToken         String                         @unique @db.VarChar(80)
  status                    AcademyProgramEnrollmentStatus @default(PENDING_PAYMENT)
  paymentStatus             PaymentStatus                  @default(CREATED)
  paymentId                 String?                        @unique @db.Uuid
  registeredAt              DateTime                       @default(now())
  lockedAt                  DateTime?
  seatReservedAt            DateTime?
  seatReservationExpiresAt  DateTime?
  confirmedAt               DateTime?
  cancelledAt               DateTime?
  expiredAt                 DateTime?
  completedAt               DateTime?
  certificateIssuedAt       DateTime?
  certificateFileStoragePath String?                      @db.VarChar(500)
  certificateFileName       String?                        @db.VarChar(255)
  certificateUploadedAt     DateTime?
  certificateUploadedByUserId String?                      @db.Uuid
  selectedCurrencyCode      String                         @db.VarChar(3)
  selectedAmountSnapshot    Decimal                        @db.Decimal(18, 2)
  submittedCountry          String?                        @db.VarChar(3)
  lockedCountry             String?                        @db.VarChar(3)
  lockedCountrySource       String?                        @db.VarChar(30)
  contactFullName           String                         @db.VarChar(191)
  contactEmail              String?                        @db.VarChar(191)
  contactPhone              String                         @db.VarChar(50)
  contactWhatsapp           String?                        @db.VarChar(50)
  contactCountry            String?                        @db.VarChar(3)
  contactNotes              String?                        @db.VarChar(1000)
  attendanceSummarySnapshot  Json?
