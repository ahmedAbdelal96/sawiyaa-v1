  @@index([paymentId, requestedAt])
  @@index([paymentId, status])
  @@index([sessionId, status])
  @@index([destination, status])
  @@index([requestedAt])
  @@index([providerRefundRef])
  @@index([actorUserId, occurredAt])
}

model CustomerWallet {
