//////////////////////////////
// Foundation / Identity
//////////////////////////////

model User {
  id            String     @id @default(uuid()) @db.Uuid
  displayName   String?    @db.VarChar(191)
  status        UserStatus @default(ACTIVE)
  tokenVersion  Int        @default(0)
  defaultLocale String?    @db.VarChar(10)
  timezone      String?    @db.VarChar(50)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  emails              UserEmail[]
  phones              UserPhone[]
  authIdentities      AuthIdentity[]
  roles               UserRole[]
  permissionOverrides UserPermissionOverride[]
  sessions            UserSession[]
  otpChallenges       OtpChallenge[]
  passwordResetSessions PasswordResetSession[]
  twoFactorSettings   TwoFactorSetting?
  patientProfile      PatientProfile?
  practitionerProfile PractitionerProfile?
  academyLearner      AcademyLearner?
  academyProgramEnrollments AcademyProgramEnrollment[]
  academyProgramCertificatesUploaded AcademyProgramEnrollment[] @relation("AcademyProgramEnrollmentCertificateUploadedByUser")
  academyProgramSessionAttendancesMarked AcademyProgramSessionAttendance[] @relation("AcademyProgramSessionAttendanceMarkedByUser")
  sessionReviewsModerated            SessionReview[]                      @relation("SessionReviewModeratedByUser")
  sessionPackageEntitlementDecisions SessionPackageEntitlementDecision[]

  authoredArticles                              Article[]                               @relation("ArticleAuthorUser")
  configChanges                                 ConfigChangeLog[]                       @relation("ConfigChangeByUser")
  auditEvents                                   AuditEvent[]                            @relation("AuditEventActorUser")
  securityAuditLogs                             SecurityAuditLog[]                      @relation("SecurityAuditLogActorUser")
  sessionEventsAsActor                          SessionEvent[]                          @relation("SessionEventActorUser")
  paymentEventsAsActor                          PaymentEvent[]                          @relation("PaymentEventActorUser")
  refundAuditActors                             Refund[]                                @relation("RefundAuditActorUser")
  walletEntryAuditActors                        CustomerWalletEntry[]                   @relation("CustomerWalletEntryAuditActorUser")
  recoveryActionAuditActors                     PractitionerRecoveryAction[]            @relation("PractitionerRecoveryActionAuditActorUser")
  settlementPayoutAuditActors                   PractitionerSettlementPayout[]         @relation("PractitionerSettlementPayoutAuditActorUser")
  refundEventsAsActor                           RefundEvent[]                           @relation("RefundEventActorUser")
  ledgerClassificationEventsAsActor             LedgerClassificationEvent[]             @relation("LedgerClassificationEventActorUser")
  financeReconciliationActionsAsActor           FinanceReconciliationAction[]           @relation("FinanceReconciliationActionActorUser")
  notificationPreferences                       NotificationPreference[]
  notifications                                 Notification[]
  notificationDevices                           NotificationDevice[]
  refundPolicyAcceptances                       RefundPolicyAcceptance[]
  inAppNotificationFeedStates                   InAppNotificationFeedState[]
  sessionReminderQueueRecipientEntries          SessionReminderQueue[]
  academyProgramsCreated                        AcademyProgram[]                        @relation("AcademyProgramCreatedByUser")
  academyProgramSessionsCreated                 AcademyProgramSession[]                 @relation("AcademyProgramSessionCreatedByUser")
  settlementPayouts                             PractitionerSettlementPayout[]
  recordedManualPayouts                         PractitionerManualPayout[]
  practitionerRecoveriesCreated                 PractitionerRecovery[]                  @relation("PractitionerRecoveryCreatedByUser")
  practitionerRecoveriesResolved                PractitionerRecovery[]                  @relation("PractitionerRecoveryResolvedByUser")
  practitionerRecoveryActionsPerformed          PractitionerRecoveryAction[]            @relation("PractitionerRecoveryActionPerformedByUser")
  financeReconciliationReviews                  FinanceReconciliationReview[]
  accountingReconciliationRuns                  AccountingReconciliationRun[]
  accountingReconciliationIssueAcknowledgements AccountingReconciliationIssue[]         @relation("AccountingReconciliationIssueAcknowledgedBy")
  accountingReconciliationIssueResolutions      AccountingReconciliationIssue[]         @relation("AccountingReconciliationIssueResolvedBy")
  accountingReconciliationIssueIgnores          AccountingReconciliationIssue[]         @relation("AccountingReconciliationIssueIgnoredBy")
  sessionCancellationRecords                    SessionCancellationRecord[]             @relation("SessionCancellationRecordCancelledByUser")
  createdMarketingPlacements                    PractitionerMarketingPlacement[]        @relation("PractitionerMarketingPlacementCreatedByAdmin")
  pausedMarketingPlacements                     PractitionerMarketingPlacement[]        @relation("PractitionerMarketingPlacementPausedByAdmin")
  marketingPlacementHistoryEntries              PractitionerMarketingPlacementHistory[]
  sessionAdminDecisions                         SessionAdminDecision[]

  @@index([status, createdAt])
}

model UserEmail {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  email      String   @unique @db.VarChar(191)
  isPrimary  Boolean  @default(false)
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isPrimary])
}

model UserPhone {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  phone      String   @unique @db.VarChar(30)
  isPrimary  Boolean  @default(false)
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isPrimary])
}

model AuthIdentity {
  id              String       @id @default(uuid()) @db.Uuid
  userId          String       @db.Uuid
  provider        AuthProvider
  providerSubject String?      @db.VarChar(191)
  passwordHash    String?      @db.VarChar(255)
  isEnabled       Boolean      @default(true)
  lastUsedAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
  @@index([userId, provider])
}

model UserRole {
  id        String       @id @default(uuid()) @db.Uuid
  userId    String       @db.Uuid
  role      UserRoleType
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([role])
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique @db.VarChar(120)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]
  userOverrides   UserPermissionOverride[]
}

model RolePermission {
  id           String       @id @default(uuid()) @db.Uuid
  role         UserRoleType
  permissionId String       @db.Uuid
  createdAt    DateTime     @default(now())

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@index([role])
  @@index([permissionId])
}

model UserPermissionOverride {
  id           String                   @id @default(uuid()) @db.Uuid
  userId       String                   @db.Uuid
  permissionId String                   @db.Uuid
  effect       PermissionOverrideEffect
  reason       String?                  @db.VarChar(255)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([userId])
  @@index([permissionId])
}

model UserSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  refreshTokenHash String?   @db.VarChar(255)
  deviceId         String?   @db.VarChar(191)
  ipAddress        String?   @db.VarChar(64)
  userAgent        String?   @db.VarChar(500)
  expiresAt        DateTime?
  revokedAt        DateTime?
  stepUpVerifiedAt DateTime?
  stepUpExpiresAt  DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@index([stepUpExpiresAt])
}

model OtpChallenge {
  id            String     @id @default(uuid()) @db.Uuid
  userId        String?    @db.Uuid
  sessionId     String?    @db.Uuid
  purpose       OtpPurpose
  channel       OtpChannel
  target        String     @db.VarChar(191)
  codeHash      String     @db.VarChar(255)
  expiresAt     DateTime
  consumedAt    DateTime?
  invalidatedAt DateTime?
  attemptCount  Int        @default(0)
  maxAttempts   Int        @default(5)
  metadata      Json?
  createdAt     DateTime   @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, purpose])
  @@index([target, purpose])
  @@index([expiresAt])
}

model PasswordResetSession {
  id            String       @id @default(uuid()) @db.Uuid
  userId         String       @db.Uuid
  role           UserRoleType
  tokenHash      String       @unique @db.VarChar(255)
  expiresAt      DateTime
  consumedAt     DateTime?
  invalidatedAt  DateTime?
  createdAt      DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, role])
  @@index([expiresAt])
}

model TwoFactorSetting {
  id               String      @id @default(uuid()) @db.Uuid
  userId           String      @unique @db.Uuid
  isRequired       Boolean     @default(false)
  preferredChannel OtpChannel?
  fallbackChannel  OtpChannel?
  enabledAt        DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

//////////////////////////////
// Profiles / Geography / Specialties
//////////////////////////////

model Country {
  id           String   @id @default(uuid()) @db.Uuid
  isoCode      String   @unique @db.VarChar(3)
  slug         String   @unique @db.VarChar(191)
  name         String   @db.VarChar(191)
  nativeName   String?  @db.VarChar(191)
  phoneCode    String?  @db.VarChar(10)
  currencyCode String?  @db.VarChar(3)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  patientProfiles      PatientProfile[]
  practitionerProfiles PractitionerProfile[]
}

model Language {
  id         String   @id @default(uuid()) @db.Uuid
  code       String   @unique @db.VarChar(10)
  slug       String   @unique @db.VarChar(191)
  name       String   @db.VarChar(191)
  nativeName String?  @db.VarChar(191)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  practitionerLanguages PractitionerProfileLanguage[]
}

model PatientProfile {
  id                    String    @id @default(uuid()) @db.Uuid
  userId                String    @unique @db.Uuid
  countryId             String?   @db.Uuid
  displayName           String?   @db.VarChar(191)
  gender                String?   @db.VarChar(50)
  dateOfBirth           DateTime? @db.Date
  onboardingCompletedAt DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  country Country? @relation(fields: [countryId], references: [id], onDelete: SetNull)

  sessions               Session[]
  instantBookingRequests InstantBookingRequest[]
  payments               Payment[]
  packagePurchases       PatientPackagePurchase[]
  packageEntitlementDecisions SessionPackageEntitlementDecision[]
  packageSettlements     PackageSettlement[]
  wallets                CustomerWallet[]
  walletEntries          CustomerWalletEntry[]
  walletReservations     CustomerWalletReservation[]
  conversations          Conversation[]              @relation("ConversationPatient")
  supportTickets         SupportTicket[]             @relation("SupportTicketPatient")
  chatApprovalRequests   ChatApprovalRequest[]
  couponRedemptions      CouponRedemption[]
  sessionReviews         SessionReview[]
  matchingSessions       MatchingSession[]
  assessmentSubmissions  AssessmentSubmission[]
  practitionerViews      PatientPractitionerView[]

  @@index([countryId])
}

model Specialty {
  id         String   @id @default(uuid()) @db.Uuid
  categoryId String?  @db.Uuid
  slug       String   @unique @db.VarChar(191)
  nameAr     String?  @db.VarChar(191)
  nameEn     String?  @db.VarChar(191)
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category              SpecialtyCategory?              @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  translations          SpecialtyTranslation[]
  practitionerLinks     PractitionerSpecialty[]
  commissionRules       CommissionRule[]
  corporateBenefitPlans CorporateBenefitPlanSpecialty[]

  @@index([categoryId, isActive, sortOrder])
  @@index([isActive, sortOrder])
}

model SpecialtyCategory {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique @db.VarChar(191)
  name        String   @db.VarChar(191)
  nameAr      String?  @db.VarChar(191)
  nameEn      String?  @db.VarChar(191)
  description String?  @db.VarChar(1000)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  specialties          Specialty[]
  practitionerProfiles PractitionerProfile[]

  @@index([isActive, sortOrder])
}

model SpecialtyTranslation {
  id          String        @id @default(uuid()) @db.Uuid
  specialtyId String        @db.Uuid
  locale      ContentLocale
  title       String        @db.VarChar(191)
  description String?       @db.VarChar(1000)
  slug        String        @db.VarChar(191)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  specialty Specialty @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  @@unique([specialtyId, locale])
  @@unique([locale, slug])
  @@index([locale, title])
}

model PractitionerProfile {
  id                         String              @id @default(uuid()) @db.Uuid
  userId                     String              @unique @db.Uuid
  countryId                  String?             @db.Uuid
  primarySpecialtyCategoryId String?             @db.Uuid
  practitionerType           PractitionerType    @default(OTHER)
  practitionerGender         PractitionerGender?
  publicSlug                 String              @unique @db.VarChar(191)
  professionalTitle          String?             @db.VarChar(191)
  bio                        String?             @db.VarChar(4000)
  yearsOfExperience          Int?
  sessionPrice30             Decimal?            @db.Decimal(18, 2)
  sessionPrice60             Decimal?            @db.Decimal(18, 2)
  sessionPrice30Egp          Decimal?            @db.Decimal(18, 2)
  sessionPrice30Usd          Decimal?            @db.Decimal(18, 2)
  sessionPrice60Egp          Decimal?            @db.Decimal(18, 2)
  sessionPrice60Usd          Decimal?            @db.Decimal(18, 2)
  instantBookingPrice30Egp   Decimal?            @db.Decimal(18, 2)
  instantBookingPrice30Usd   Decimal?            @db.Decimal(18, 2)
  instantBookingPrice60Egp   Decimal?            @db.Decimal(18, 2)
  instantBookingPrice60Usd   Decimal?            @db.Decimal(18, 2)
  avatarUrl                  String?             @db.Text
  coverImageUrl              String?             @db.VarChar(500)
  isPublicProfilePublished   Boolean             @default(false)
  status                     PractitionerStatus  @default(DRAFT)
  isOnlineToggleEnabled      Boolean             @default(false)
  isInstantBookingEnabled    Boolean             @default(false)
  acceptsPackages            Boolean             @default(false)
  preferredPayoutCurrencyCode String              @default("EGP") @db.VarChar(3)
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt

  user                     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  country                  Country?           @relation(fields: [countryId], references: [id], onDelete: SetNull)
  primarySpecialtyCategory SpecialtyCategory? @relation(fields: [primarySpecialtyCategoryId], references: [id], onDelete: SetNull)

  languages               PractitionerProfileLanguage[]
  specialties             PractitionerSpecialty[]
  applications            PractitionerApplication[]
  credentials             PractitionerCredential[]
  payoutDestination       PractitionerPayoutDestination?
  availabilityExceptions  AvailabilityException[]
  availabilityWeeks       PractitionerAvailabilityWeek[]
  presence                PractitionerPresence?
  sessions                Session[]
  instantBookingRequests  InstantBookingRequest[]
  payments                Payment[]
  packagePurchases        PatientPackagePurchase[]
  packageEntitlementDecisions SessionPackageEntitlementDecision[]
  packageSettlements      PackageSettlement[]
  wallets                 PractitionerWallet[]
  ledgerEntries           LedgerEntry[]
  settlements             PractitionerSettlement[]
  settlementPayouts       PractitionerSettlementPayout[]
  manualPayouts           PractitionerManualPayout[]
  practitionerRecoveries  PractitionerRecovery[]
  coupons                 Coupon[]
  articles                Article[]                          @relation("ArticleAuthorPractitioner")
  conversations           Conversation[]                     @relation("ConversationPractitioner")
  supportTickets          SupportTicket[]                    @relation("SupportTicketPractitioner")
  chatApprovalRequests    ChatApprovalRequest[]
  couponRedemptions       CouponRedemption[]
  sessionReviews          SessionReview[]
  matchingRecommendations MatchingRecommendation[]
  corporateBenefitPlans   CorporateBenefitPlanPractitioner[]
  patientViews            PatientPractitionerView[]
  marketingPlacements     PractitionerMarketingPlacement[]

  @@index([status, practitionerType])
  @@index([practitionerGender, status])
  @@index([countryId, status])
  @@index([primarySpecialtyCategoryId, status])
}

model PatientPractitionerView {
  id             String   @id @default(uuid()) @db.Uuid
  patientId      String   @db.Uuid
  practitionerId String   @db.Uuid
  firstViewedAt  DateTime @default(now())
  lastViewedAt   DateTime @default(now())
  viewCount      Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  patient      PatientProfile      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  practitioner PractitionerProfile @relation(fields: [practitionerId], references: [id], onDelete: Cascade)

  @@unique([patientId, practitionerId])
  @@index([patientId, lastViewedAt])
  @@index([practitionerId])
}

model PractitionerMarketingPlacement {
  id               String                                @id @default(uuid()) @db.Uuid
  practitionerId   String                                @db.Uuid
  surface          PractitionerMarketingPlacementSurface
  status           PractitionerMarketingPlacementStatus  @default(ACTIVE)
  startsAt         DateTime
  endsAt           DateTime?
  priority         Int                                   @default(100)
  badgeLabelAr     String?                               @db.VarChar(191)
  badgeLabelEn     String?                               @db.VarChar(191)
  reason           PractitionerMarketingPlacementReason  @default(FEATURED)
  campaignName     String?                               @db.VarChar(191)
  notesInternal    String?                               @db.VarChar(2000)
  createdByAdminId String?                               @db.Uuid
  pausedByAdminId  String?                               @db.Uuid
  pausedAt         DateTime?
  createdAt        DateTime                              @default(now())
  updatedAt        DateTime                              @updatedAt

  practitioner   PractitionerProfile                     @relation(fields: [practitionerId], references: [id], onDelete: Cascade)
  createdByAdmin User?                                   @relation("PractitionerMarketingPlacementCreatedByAdmin", fields: [createdByAdminId], references: [id], onDelete: SetNull)
  pausedByAdmin  User?                                   @relation("PractitionerMarketingPlacementPausedByAdmin", fields: [pausedByAdminId], references: [id], onDelete: SetNull)
  historyEntries PractitionerMarketingPlacementHistory[]

  @@index([surface, status, startsAt, endsAt, priority])
  @@index([practitionerId])
  @@index([status, startsAt, endsAt])
}

model PractitionerMarketingPlacementHistory {
  id             String                                      @id @default(uuid()) @db.Uuid
  placementId    String                                      @db.Uuid
  action         PractitionerMarketingPlacementHistoryAction
  actorUserId    String?                                     @db.Uuid
  beforeSnapshot Json?
  afterSnapshot  Json?
  note           String?                                     @db.VarChar(1000)
  createdAt      DateTime                                    @default(now())

  placement PractitionerMarketingPlacement @relation(fields: [placementId], references: [id], onDelete: Cascade)
  actorUser User?                          @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([placementId, createdAt])
  @@index([actorUserId, createdAt])
}

model PatientPackagePurchase {
  id                                String                       @id @default(uuid()) @db.Uuid
  packagePlanId                     String?                      @db.Uuid
  practitionerId                    String                       @db.Uuid
  patientId                         String                       @db.Uuid
  paymentId                         String?                      @unique @db.Uuid
  status                            PatientPackagePurchaseStatus @default(PENDING_PAYMENT)
  paymentInitiatedAt                DateTime?
  paymentExpiresAt                  DateTime?
  paidAt                            DateTime?
  activatedAt                       DateTime?
  completedAt                       DateTime?
  expiredAt                         DateTime?
  cancelledAt                       DateTime?
  refundedAt                        DateTime?
  titleSnapshot                     String                       @db.VarChar(191)
  descriptionSnapshot               String?                      @db.VarChar(4000)
  slugSnapshot                      String                       @db.VarChar(191)
  packageVersionSnapshot            Int
  planIdSnapshot                    String?                      @db.Uuid
  planCodeSnapshot                  String?                      @db.VarChar(100)
  sessionCountSnapshot              Int
  discountPercentSnapshot           Decimal?                     @db.Decimal(5, 2)
  baseSessionPriceEgpSnapshot       Decimal?                     @db.Decimal(18, 2)
  baseSessionPriceUsdSnapshot       Decimal?                     @db.Decimal(18, 2)
  currencyCodeSnapshot              String?                      @db.VarChar(3)
  selectedBaseSessionPriceSnapshot  Decimal?                     @db.Decimal(18, 2)
  undiscountedTotalSnapshot         Decimal?                     @db.Decimal(18, 2)
  discountAmountSnapshot            Decimal?                     @db.Decimal(18, 2)
  patientPayableTotalSnapshot       Decimal?                     @db.Decimal(18, 2)
  platformDiscountShareSnapshot     Decimal?                     @db.Decimal(18, 2)
  practitionerDiscountShareSnapshot Decimal?                     @db.Decimal(18, 2)
  commissionModeSnapshot            String?                      @db.VarChar(50)
  platformOriginalShareSnapshot     Decimal?                     @db.Decimal(18, 2)
  practitionerOriginalShareSnapshot Decimal?                     @db.Decimal(18, 2)
  platformFinalShareSnapshot        Decimal?                     @db.Decimal(18, 2)
  practitionerFinalShareSnapshot    Decimal?                     @db.Decimal(18, 2)
  sessionDurationMinutesSnapshot    Int
  sessionModeSnapshot               SessionMode
  schedulePolicySnapshot            PackageSchedulePolicy
  priceEgpSnapshot                  Decimal?                     @db.Decimal(18, 2)
  priceUsdSnapshot                  Decimal?                     @db.Decimal(18, 2)
  selectedCurrencyCode              String                       @db.VarChar(3)
  selectedAmountSnapshot            Decimal                      @db.Decimal(18, 2)
  metadataJson                      Json?
  createdAt                         DateTime                     @default(now())
  updatedAt                         DateTime                     @updatedAt

  packagePlan       PackagePlan?        @relation(fields: [packagePlanId], references: [id], onDelete: SetNull)
  practitioner      PractitionerProfile @relation(fields: [practitionerId], references: [id], onDelete: Restrict)
  patient           PatientProfile      @relation(fields: [patientId], references: [id], onDelete: Restrict)
  payment           Payment?            @relation("PatientPackagePurchasePayment", fields: [paymentId], references: [id], onDelete: SetNull)
  sessions          Session[]           @relation("SessionPackagePurchase")
  packageEntitlementDecisions SessionPackageEntitlementDecision[]
  packageSettlement PackageSettlement?

  @@index([packagePlanId, status, createdAt])
  @@index([practitionerId, status, createdAt])
  @@index([patientId, status, createdAt])
  @@index([status, paymentExpiresAt])
}

model PackageSettlement {
  id                           String                  @id @default(uuid()) @db.Uuid
  purchaseId                   String                  @unique @db.Uuid
  practitionerId               String                  @db.Uuid
  patientId                    String                  @db.Uuid
  currencyCode                 String                  @db.VarChar(3)
  status                       PackageSettlementStatus @default(HELD)
  sessionCount                 Int
  completedSessionsCount       Int                     @default(0)
  heldPractitionerAmount       Decimal                 @default(0) @db.Decimal(18, 2)
  heldPlatformAmount           Decimal                 @default(0) @db.Decimal(18, 2)
  releasablePractitionerAmount Decimal                 @default(0) @db.Decimal(18, 2)
