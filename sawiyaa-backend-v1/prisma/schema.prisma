  @@unique([userId, notificationTypeId, channel])
  @@index([userId, channel])
  @@index([notificationTypeId, channel, isEnabled])
}

model Notification {
  id                 String  @id @default(uuid()) @db.Uuid
  userId             String  @db.Uuid
  notificationTypeId String  @db.Uuid
  templateId         String? @db.Uuid

  channel NotificationChannel
  status  NotificationStatus  @default(PENDING)
  locale  String?             @db.VarChar(10)

  payloadJson     Json?
  titleSnapshot   String? @db.VarChar(300)
  subjectSnapshot String? @db.VarChar(300)
  bodySnapshot    String?

  relatedEntityType String? @db.VarChar(100)
  relatedEntityId   String? @db.VarChar(191)
  idempotencyKey    String? @db.VarChar(191)

  scheduledFor     DateTime?
  sentAt           DateTime?
  deliveredAt      DateTime?
  readAt           DateTime?
  failedAt         DateTime?
  suppressedReason String?   @db.VarChar(500)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user             User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  notificationType NotificationType              @relation(fields: [notificationTypeId], references: [id], onDelete: Restrict)
  template         NotificationTemplate?         @relation(fields: [templateId], references: [id], onDelete: SetNull)
  deliveryAttempts NotificationDeliveryAttempt[]
  feedStates       InAppNotificationFeedState[]

  @@unique([idempotencyKey])
  @@index([userId, channel, status, scheduledFor, createdAt])
  @@index([userId, status, createdAt])
  @@index([userId, channel, createdAt])
  @@index([notificationTypeId, channel, createdAt])
  @@index([scheduledFor, status])
  @@index([relatedEntityType, relatedEntityId])
  @@index([readAt])
  @@index([failedAt])
}

