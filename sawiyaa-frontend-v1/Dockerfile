FROM node:20-bookworm-slim AS base

WORKDIR /app
ENV CI=true

FROM base AS deps
COPY package*.json ./
RUN npm ci

FROM deps AS build
ARG NEXT_PUBLIC_API_URL=/api/v1
ARG API_PROXY_TARGET=http://backend:7000
ARG NEXT_PUBLIC_APP_NAME=Sawiyaa
ARG NEXT_PUBLIC_APP_URL=https://sawiyaa.com
ARG NEXT_PUBLIC_SITE_URL=https://sawiyaa.com
ARG NEXT_PUBLIC_APP_ENV=production
ARG NEXT_PUBLIC_SHOW_DETAILED_ERRORS=false
ARG NEXT_PUBLIC_TOKEN_EXPIRY_DAYS=7
ARG NEXT_PUBLIC_REFRESH_TOKEN_EXPIRY_DAYS=30
ARG NEXT_PUBLIC_CHAT_SOCKET_URL=https://sawiyaa.com
ARG NEXT_PUBLIC_GOOGLE_CLIENT_ID=
ARG NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
ARG NEXT_PUBLIC_SHOW_TEST_CREDENTIALS=false
ARG NEXT_PUBLIC_PRACTITIONER_LOGIN_OTP_ENABLED=true
ARG NEXT_PUBLIC_ENABLE_ANALYTICS=false
ARG NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
ARG NEXT_PUBLIC_ENABLE_DEVTOOLS=false
ARG NEXT_PUBLIC_DEBUG_PRACTITIONER_WIZARD=0
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
ENV API_PROXY_TARGET=${API_PROXY_TARGET}
ENV NEXT_PUBLIC_APP_NAME=${NEXT_PUBLIC_APP_NAME}
ENV NEXT_PUBLIC_APP_URL=${NEXT_PUBLIC_APP_URL}
ENV NEXT_PUBLIC_SITE_URL=${NEXT_PUBLIC_SITE_URL}
ENV NEXT_PUBLIC_APP_ENV=${NEXT_PUBLIC_APP_ENV}
ENV NEXT_PUBLIC_SHOW_DETAILED_ERRORS=${NEXT_PUBLIC_SHOW_DETAILED_ERRORS}
ENV NEXT_PUBLIC_TOKEN_EXPIRY_DAYS=${NEXT_PUBLIC_TOKEN_EXPIRY_DAYS}
ENV NEXT_PUBLIC_REFRESH_TOKEN_EXPIRY_DAYS=${NEXT_PUBLIC_REFRESH_TOKEN_EXPIRY_DAYS}
ENV NEXT_PUBLIC_CHAT_SOCKET_URL=${NEXT_PUBLIC_CHAT_SOCKET_URL}
ENV NEXT_PUBLIC_GOOGLE_CLIENT_ID=${NEXT_PUBLIC_GOOGLE_CLIENT_ID}
ENV NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=${NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY}
ENV NEXT_PUBLIC_SHOW_TEST_CREDENTIALS=${NEXT_PUBLIC_SHOW_TEST_CREDENTIALS}
ENV NEXT_PUBLIC_PRACTITIONER_LOGIN_OTP_ENABLED=${NEXT_PUBLIC_PRACTITIONER_LOGIN_OTP_ENABLED}
ENV NEXT_PUBLIC_ENABLE_ANALYTICS=${NEXT_PUBLIC_ENABLE_ANALYTICS}
ENV NEXT_PUBLIC_ENABLE_NOTIFICATIONS=${NEXT_PUBLIC_ENABLE_NOTIFICATIONS}
ENV NEXT_PUBLIC_ENABLE_DEVTOOLS=${NEXT_PUBLIC_ENABLE_DEVTOOLS}
ENV NEXT_PUBLIC_DEBUG_PRACTITIONER_WIZARD=${NEXT_PUBLIC_DEBUG_PRACTITIONER_WIZARD}

COPY . .
RUN npm run build

FROM base AS runtime
ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
ENV NEXT_PUBLIC_API_URL=/api/v1
ENV API_PROXY_TARGET=http://backend:7000
ENV NEXT_PUBLIC_APP_URL=https://sawiyaa.com
ENV NEXT_PUBLIC_SITE_URL=https://sawiyaa.com
ENV NEXT_PUBLIC_APP_ENV=production
ENV NEXT_PUBLIC_SHOW_DETAILED_ERRORS=false
ENV NEXT_PUBLIC_TOKEN_EXPIRY_DAYS=7
ENV NEXT_PUBLIC_REFRESH_TOKEN_EXPIRY_DAYS=30
ENV NEXT_PUBLIC_CHAT_SOCKET_URL=https://sawiyaa.com
ENV NEXT_PUBLIC_SHOW_TEST_CREDENTIALS=false
ENV NEXT_PUBLIC_PRACTITIONER_LOGIN_OTP_ENABLED=true
ENV NEXT_PUBLIC_ENABLE_ANALYTICS=false
ENV NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
ENV NEXT_PUBLIC_ENABLE_DEVTOOLS=false
ENV NEXT_PUBLIC_DEBUG_PRACTITIONER_WIZARD=0
WORKDIR /app

COPY package*.json ./
COPY --from=deps /app/node_modules ./node_modules
COPY --from=build --chown=node:node /app/.next ./.next
COPY --from=build --chown=node:node /app/public ./public
COPY --from=build --chown=node:node /app/messages ./messages
COPY --from=build --chown=node:node /app/src ./src
COPY --from=build --chown=node:node /app/next.config.ts ./next.config.ts
COPY --from=build --chown=node:node /app/next-env.d.ts ./next-env.d.ts
COPY --from=build --chown=node:node /app/postcss.config.js ./postcss.config.js

USER node

EXPOSE 3000

CMD ["npm", "run", "start"]
