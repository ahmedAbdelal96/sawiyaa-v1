# Sawiyaa frontend production example
# Build-time public vars are baked into the Next.js bundle.

NEXT_PUBLIC_API_URL=/api/v1
API_PROXY_TARGET=http://backend:7000

NEXT_PUBLIC_APP_NAME=Sawiyaa
NEXT_PUBLIC_APP_URL=https://sawiyaa.com
NEXT_PUBLIC_SITE_URL=https://sawiyaa.com
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_SHOW_DETAILED_ERRORS=false
NEXT_PUBLIC_TOKEN_EXPIRY_DAYS=7
NEXT_PUBLIC_REFRESH_TOKEN_EXPIRY_DAYS=30
NEXT_PUBLIC_CHAT_SOCKET_URL=https://sawiyaa.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=<change-me>
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=<change-me>
NEXT_PUBLIC_SHOW_TEST_CREDENTIALS=false
NEXT_PUBLIC_PRACTITIONER_LOGIN_OTP_ENABLED=true
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
NEXT_PUBLIC_ENABLE_DEVTOOLS=false
NEXT_PUBLIC_DEBUG_PRACTITIONER_WIZARD=0

# Runtime host binding for the Next.js server
HOSTNAME=0.0.0.0
PORT=3000
