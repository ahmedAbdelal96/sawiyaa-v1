generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Locale {
  AR
  EN
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum AuthProvider {
  PASSWORD
  GOOGLE
}

enum RoleCode {
  PATIENT
  PRACTITIONER
  ADMIN
  SUPPORT
  CONTENT_REVIEWER
  SUPER_ADMIN
}

enum OtpPurpose {
  LOGIN
  VERIFY_EMAIL
  VERIFY_PHONE
  RESET_PASSWORD
}

enum OtpChannel {
  EMAIL
  SMS
}

enum TwoFactorMode {
  OFF
  OPTIONAL
  REQUIRED
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
}

enum CredentialType {
  LICENSE
  DEGREE
  CERTIFICATION
  NATIONAL_ID
  OTHER
}

enum CredentialStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY
}

model User {
  id                 String              @id @default(uuid()) @db.Uuid
  displayName        String?             @map("display_name") @db.VarChar(120)
  status             UserStatus          @default(PENDING)
  defaultLocale      Locale              @default(AR) @map("default_locale")
  timezone           String              @default("Africa/Cairo") @db.VarChar(64)
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  emails             UserEmail[]
  phones             UserPhone[]
  identities         AuthIdentity[]
  roles              UserRole[]
  sessions           UserSession[]
  otpChallenges      OtpChallenge[]
  twoFactorSetting   TwoFactorSetting?
  patientProfile     PatientProfile?
  practitionerProfile PractitionerProfile?

  reviewedApplications PractitionerApplication[] @relation("ApplicationReviewer")
  reviewedCredentials  PractitionerCredential[]  @relation("CredentialReviewer")

  @@index([status])
  @@map("users")
}

model UserEmail {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  email           String    @db.VarChar(255)
  normalizedEmail String    @unique @map("normalized_email") @db.VarChar(255)
  isPrimary       Boolean   @default(false) @map("is_primary")
  isVerified      Boolean   @default(false) @map("is_verified")
  verifiedAt      DateTime? @map("verified_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_emails")
}

model UserPhone {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  phone      String    @db.VarChar(32)
  e164       String    @unique @db.VarChar(20)
  isPrimary  Boolean   @default(false) @map("is_primary")
  isVerified Boolean   @default(false) @map("is_verified")
  verifiedAt DateTime? @map("verified_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_phones")
}

model AuthIdentity {
  id              String       @id @default(uuid()) @db.Uuid
  userId          String       @map("user_id") @db.Uuid
  provider        AuthProvider
  providerSubject String?      @map("provider_subject") @db.VarChar(191)
  providerEmail   String?      @map("provider_email") @db.VarChar(255)
  passwordHash    String?      @map("password_hash") @db.VarChar(255)
  isEnabled       Boolean      @default(true) @map("is_enabled")
  lastUsedAt      DateTime?    @map("last_used_at") @db.Timestamptz(6)
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@unique([provider, providerSubject])
  @@index([userId])
  @@map("auth_identities")
}

model UserRole {
  userId     String   @map("user_id") @db.Uuid
  role       RoleCode
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, role])
  @@map("user_roles")
}

model UserSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @unique @map("refresh_token_hash") @db.VarChar(255)
  ipAddress        String?   @map("ip_address") @db.VarChar(64)
  userAgent        String?   @map("user_agent") @db.VarChar(1024)
  deviceName       String?   @map("device_name") @db.VarChar(120)
  lastActivityAt   DateTime? @map("last_activity_at") @db.Timestamptz(6)
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("user_sessions")
}

model OtpChallenge {
  id            String     @id @default(uuid()) @db.Uuid
  userId        String     @map("user_id") @db.Uuid
  purpose       OtpPurpose
  channel       OtpChannel
  target        String     @db.VarChar(255)
  codeHash      String     @map("code_hash") @db.VarChar(255)
  attemptsCount Int        @default(0) @map("attempts_count")
  maxAttempts   Int        @default(5) @map("max_attempts")
  expiresAt     DateTime   @map("expires_at") @db.Timestamptz(6)
  consumedAt    DateTime?  @map("consumed_at") @db.Timestamptz(6)
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("otp_challenges")
}

model TwoFactorSetting {
  userId           String         @id @map("user_id") @db.Uuid
  mode             TwoFactorMode  @default(OFF)
  preferredChannel OtpChannel?    @map("preferred_channel")
  fallbackChannel  OtpChannel?    @map("fallback_channel")
  otpTtlSeconds    Int            @default(300) @map("otp_ttl_seconds")
  enabledAt        DateTime?      @map("enabled_at") @db.Timestamptz(6)
  updatedAt        DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("two_factor_settings")
}

model PatientProfile {
  userId                String    @id @map("user_id") @db.Uuid
  firstName             String?   @map("first_name") @db.VarChar(80)
  lastName              String?   @map("last_name") @db.VarChar(80)
  dateOfBirth           DateTime? @map("date_of_birth") @db.Date
  gender                Gender?
  countryCode           String?   @map("country_code") @db.Char(2)
  city                  String?   @db.VarChar(120)
  avatarUrl             String?   @map("avatar_url") @db.VarChar(500)
  marketingConsent      Boolean   @default(false) @map("marketing_consent")
  onboardingCompletedAt DateTime? @map("onboarding_completed_at") @db.Timestamptz(6)
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("patient_profiles")
}

model PractitionerProfile {
  userId               String            @id @map("user_id") @db.Uuid
  publicSlug           String            @unique @map("public_slug") @db.VarChar(160)
  headline             String?           @db.VarChar(180)
  bio                  String?
  yearsOfExperience    Int?              @map("years_of_experience")
  countryCode          String?           @map("country_code") @db.Char(2)
  city                 String?           @db.VarChar(120)
  approvalStatus       ApplicationStatus @default(DRAFT) @map("approval_status")
  isListed             Boolean           @default(false) @map("is_listed")
  acceptingNewClients  Boolean           @default(false) @map("accepting_new_clients")
  createdAt            DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  user         User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications PractitionerApplication[]
  credentials  PractitionerCredential[]
  specialties  PractitionerSpecialty[]

  @@index([approvalStatus])
  @@index([isListed])
  @@map("practitioner_profiles")
}

model PractitionerApplication {
  id             String            @id @default(uuid()) @db.Uuid
  practitionerId String            @map("practitioner_id") @db.Uuid
  status         ApplicationStatus @default(DRAFT)
  submittedAt    DateTime?         @map("submitted_at") @db.Timestamptz(6)
  reviewedAt     DateTime?         @map("reviewed_at") @db.Timestamptz(6)
  reviewerUserId String?           @map("reviewer_user_id") @db.Uuid
  reviewNotes    String?           @map("review_notes")
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  practitioner PractitionerProfile @relation(fields: [practitionerId], references: [userId], onDelete: Cascade)
  reviewer     User?               @relation("ApplicationReviewer", fields: [reviewerUserId], references: [id], onDelete: SetNull)

  @@index([practitionerId])
  @@index([status])
  @@map("practitioner_applications")
}

model PractitionerCredential {
  id             String           @id @default(uuid()) @db.Uuid
  practitionerId String           @map("practitioner_id") @db.Uuid
  type           CredentialType
  title          String?          @db.VarChar(180)
  issuer         String?          @db.VarChar(180)
  licenseNumber  String?          @map("license_number") @db.VarChar(120)
  countryCode    String?          @map("country_code") @db.Char(2)
  fileUrl        String           @map("file_url") @db.VarChar(500)
  status         CredentialStatus @default(PENDING)
  expiresAt      DateTime?        @map("expires_at") @db.Date
  reviewedAt     DateTime?        @map("reviewed_at") @db.Timestamptz(6)
  reviewerUserId String?          @map("reviewer_user_id") @db.Uuid
  reviewNotes    String?          @map("review_notes")
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  practitioner PractitionerProfile @relation(fields: [practitionerId], references: [userId], onDelete: Cascade)
  reviewer     User?               @relation("CredentialReviewer", fields: [reviewerUserId], references: [id], onDelete: SetNull)

  @@index([practitionerId])
  @@index([status])
  @@map("practitioner_credentials")
}

model SpecialtyCategory {
  id           String                         @id @default(uuid()) @db.Uuid
  code         String                         @unique @db.VarChar(100)
  isActive     Boolean                        @default(true) @map("is_active")
  sortOrder    Int                            @default(0) @map("sort_order")
  createdAt    DateTime                       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime                       @updatedAt @map("updated_at") @db.Timestamptz(6)

  translations SpecialtyCategoryTranslation[]
  specialties  Specialty[]

  @@map("specialty_categories")
}

model SpecialtyCategoryTranslation {
  id          String            @id @default(uuid()) @db.Uuid
  categoryId  String            @map("category_id") @db.Uuid
  locale      Locale
  name        String            @db.VarChar(160)
  description String?

  category SpecialtyCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
  @@index([locale])
  @@map("specialty_category_translations")
}

model Specialty {
  id           String                 @id @default(uuid()) @db.Uuid
  categoryId   String                 @map("category_id") @db.Uuid
  code         String                 @unique @db.VarChar(100)
  isActive     Boolean                @default(true) @map("is_active")
  isSelectable Boolean                @default(true) @map("is_selectable")
  sortOrder    Int                    @default(0) @map("sort_order")
  createdAt    DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)

  category     SpecialtyCategory      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  translations SpecialtyTranslation[]
  practitioners PractitionerSpecialty[]

  @@index([categoryId])
  @@map("specialties")
}

model SpecialtyTranslation {
  id          String    @id @default(uuid()) @db.Uuid
  specialtyId String    @map("specialty_id") @db.Uuid
  locale      Locale
  name        String    @db.VarChar(160)
  description String?

  specialty Specialty @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  @@unique([specialtyId, locale])
  @@index([locale])
  @@map("specialty_translations")
}

model PractitionerSpecialty {
  practitionerId    String   @map("practitioner_id") @db.Uuid
  specialtyId       String   @map("specialty_id") @db.Uuid
  isPrimary         Boolean  @default(false) @map("is_primary")
  sortOrder         Int      @default(0) @map("sort_order")
  yearsOfExperience Int?     @map("years_of_experience")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  practitioner PractitionerProfile @relation(fields: [practitionerId], references: [userId], onDelete: Cascade)
  specialty    Specialty           @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  @@id([practitionerId, specialtyId])
  @@index([specialtyId])
  @@map("practitioner_specialties")
}
