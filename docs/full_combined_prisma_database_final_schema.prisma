  externalRoomProvider  String?                  @db.VarChar(100)
  externalRoomJoinUrl   String?                  @db.VarChar(500)
  externalRoomHostUrl   String?                  @db.VarChar(500)

  attendanceTrackingEnabled Boolean              @default(true)
  isMandatory           Boolean                  @default(true)

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  courseSchedule        CourseSchedule           @relation(fields: [courseScheduleId], references: [id], onDelete: Cascade)
  attendances           EnrollmentAttendance[]

  @@unique([courseScheduleId, sessionOrder])
  @@index([courseScheduleId, startsAt])
  @@index([startsAt, endsAt])
}

model Enrollment {
  id                    String                   @id @default(uuid()) @db.Uuid
  courseId              String                   @db.Uuid
  courseScheduleId      String                   @db.Uuid
  userId                String                   @db.Uuid
  paymentId             String?                  @db.Uuid

  enrollmentStatus      EnrollmentStatus         @default(PENDING_PAYMENT)
  paymentStatus         String?                  @db.VarChar(50)
  attendanceStatus      EnrollmentAttendanceStatus @default(NOT_STARTED)

  enrolledAt            DateTime                 @default(now())
  cancelledAt           DateTime?
  refundedAt            DateTime?
  completedAt           DateTime?
  notesInternal         String?                  @db.VarChar(1000)

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  course                Course                   @relation(fields: [courseId], references: [id], onDelete: Restrict)
  courseSchedule        CourseSchedule           @relation(fields: [courseScheduleId], references: [id], onDelete: Cascade)
  user                  User                     @relation(fields: [userId], references: [id], onDelete: Restrict)
  payment               Payment?                 @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  attendances           EnrollmentAttendance[]

  @@unique([courseScheduleId, userId])
  @@index([courseId, enrollmentStatus, enrolledAt])
  @@index([courseScheduleId, enrollmentStatus])
  @@index([paymentStatus])
  @@index([userId, enrollmentStatus])
}

model EnrollmentAttendance {
  id                    String                   @id @default(uuid()) @db.Uuid
  enrollmentId          String                   @db.Uuid
  courseSessionId       String                   @db.Uuid

  attendanceStatus      AttendanceStatus
  attendanceSource      AttendanceSource         @default(MANUAL)

  checkInAt             DateTime?
  checkOutAt            DateTime?
  attendedMinutes       Int?
  markedByUserId        String?                  @db.Uuid

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  enrollment            Enrollment               @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  courseSession         CourseSession            @relation(fields: [courseSessionId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, courseSessionId])
  @@index([courseSessionId, attendanceStatus])
  @@index([enrollmentId, attendanceStatus])
  @@index([markedByUserId, checkInAt])
}

model CourseApproval {
  id                    String                   @id @default(uuid()) @db.Uuid
  courseId              String                   @db.Uuid
  reviewedByUserId      String?                  @db.Uuid
  decision              CourseReviewDecision
  reviewNote            String?                  @db.VarChar(1000)
  createdAt             DateTime                 @default(now())

  course                Course                   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId, createdAt])
  @@index([reviewedByUserId, createdAt])
  @@index([decision, createdAt])
}
