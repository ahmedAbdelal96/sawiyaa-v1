// Full Combined Prisma Database Final Schema
// Platform domain: mental health / consultations / content / training
// Notes:
// - This is a combined schema draft intended as a strong foundation for NestJS + PostgreSQL + Prisma
// - UUID primary keys across all models
// - Timestamps are UTC
// - Some advanced constraints (partial indexes, overlap prevention, exclusion constraints, FTS, complex uniqueness across nullable scopes)
//   are better added via raw SQL migrations after Prisma migrations.
// - User/Auth is unified; profiles are separated by domain role.
// - Slugs are used for public/admin-readable entities, not as replacements for internal IDs in operational/financial records.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

