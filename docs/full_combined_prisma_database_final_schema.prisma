//////////////////////////////
// Foundation / Identity
//////////////////////////////

model User {
  id                    String                   @id @default(uuid()) @db.Uuid
  displayName           String?                  @db.VarChar(191)
  status                UserStatus               @default(ACTIVE)
  defaultLocale         String?                  @db.VarChar(10)
  timezone              String?                  @db.VarChar(50)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  emails                UserEmail[]
  phones                UserPhone[]
  authIdentities        AuthIdentity[]
  roles                 UserRole[]
  sessions              UserSession[]
  otpChallenges         OtpChallenge[]
  twoFactorSettings     TwoFactorSetting?
  patientProfile        PatientProfile?
  practitionerProfile   PractitionerProfile?

  authoredArticles      Article[]                @relation("ArticleAuthorUser")
  configChanges         ConfigChangeLog[]        @relation("ConfigChangeByUser")
}

model UserEmail {
  id                    String                   @id @default(uuid()) @db.Uuid
  userId                String                   @db.Uuid
  email                 String                   @unique @db.VarChar(191)
  isPrimary             Boolean                  @default(false)
  isVerified            Boolean                  @default(false)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  user                  User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isPrimary])
}

model UserPhone {
  id                    String                   @id @default(uuid()) @db.Uuid
  userId                String                   @db.Uuid
  phone                 String                   @unique @db.VarChar(30)
  isPrimary             Boolean                  @default(false)
  isVerified            Boolean                  @default(false)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  user                  User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isPrimary])
}

model AuthIdentity {
  id                    String                   @id @default(uuid()) @db.Uuid
  userId                String                   @db.Uuid
  provider              AuthProvider
  providerSubject       String?                  @db.VarChar(191)
  passwordHash          String?                  @db.VarChar(255)
  isEnabled             Boolean                  @default(true)
  lastUsedAt            DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  user                  User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
  @@index([userId, provider])
}

model UserRole {
  id                    String                   @id @default(uuid()) @db.Uuid
  userId                String                   @db.Uuid
  role                  UserRoleType
  createdAt             DateTime                 @default(now())

  user                  User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([role])
}

model UserSession {
  id                    String                   @id @default(uuid()) @db.Uuid
  userId                String                   @db.Uuid
  refreshTokenHash      String?                  @db.VarChar(255)
  deviceId              String?                  @db.VarChar(191)
  ipAddress             String?                  @db.VarChar(64)
  userAgent             String?                  @db.VarChar(500)
  expiresAt             DateTime?
  revokedAt             DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  user                  User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([expiresAt])
}

model OtpChallenge {
  id                    String                   @id @default(uuid()) @db.Uuid
  userId                String?                  @db.Uuid
  purpose               OtpPurpose
  channel               OtpChannel
  target                String                   @db.VarChar(191)
  codeHash              String                   @db.VarChar(255)
  expiresAt             DateTime
  consumedAt            DateTime?
  createdAt             DateTime                 @default(now())

  user                  User?                    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, purpose])
  @@index([target, purpose])
  @@index([expiresAt])
}

model TwoFactorSetting {
  id                    String                   @id @default(uuid()) @db.Uuid
  userId                String                   @unique @db.Uuid
  isRequired            Boolean                  @default(false)
  preferredChannel      OtpChannel?
  fallbackChannel       OtpChannel?
  enabledAt             DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  user                  User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

//////////////////////////////
// Profiles / Geography / Specialties
//////////////////////////////

model Country {
  id                    String                   @id @default(uuid()) @db.Uuid
  isoCode               String                   @unique @db.VarChar(3)
  slug                  String                   @unique @db.VarChar(191)
  name                  String                   @db.VarChar(191)
  nativeName            String?                  @db.VarChar(191)
  phoneCode             String?                  @db.VarChar(10)
  currencyCode          String?                  @db.VarChar(3)
  isActive              Boolean                  @default(true)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  patientProfiles       PatientProfile[]
  practitionerProfiles  PractitionerProfile[]
}

model Language {
  id                    String                   @id @default(uuid()) @db.Uuid
  code                  String                   @unique @db.VarChar(10)
  slug                  String                   @unique @db.VarChar(191)
  name                  String                   @db.VarChar(191)
  nativeName            String?                  @db.VarChar(191)
  isActive              Boolean                  @default(true)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  practitionerLanguages PractitionerProfileLanguage[]
}

model PatientProfile {
  id                    String                   @id @default(uuid()) @db.Uuid
  userId                String                   @unique @db.Uuid
  countryId             String?                  @db.Uuid
  displayName           String?                  @db.VarChar(191)
  gender                String?                  @db.VarChar(50)
  dateOfBirth           DateTime?                @db.Date
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  user                  User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  country               Country?                 @relation(fields: [countryId], references: [id], onDelete: SetNull)

  sessions              Session[]
  instantBookingRequests InstantBookingRequest[]
  payments              Payment[]
  conversations         Conversation[]           @relation("ConversationPatient")
  supportTickets        SupportTicket[]          @relation("SupportTicketPatient")
  chatApprovalRequests  ChatApprovalRequest[]
  couponRedemptions     CouponRedemption[]
  sessionReviews        SessionReview[]

  @@index([countryId])
}

model Specialty {
  id                    String                   @id @default(uuid()) @db.Uuid
  slug                  String                   @unique @db.VarChar(191)
  sortOrder             Int                      @default(0)
  isActive              Boolean                  @default(true)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  translations          SpecialtyTranslation[]
  practitionerLinks     PractitionerSpecialty[]
  commissionRules       CommissionRule[]

  @@index([isActive, sortOrder])
}

model SpecialtyTranslation {
  id                    String                   @id @default(uuid()) @db.Uuid
  specialtyId           String                   @db.Uuid
  locale                ContentLocale
  title                 String                   @db.VarChar(191)
  description           String?                  @db.VarChar(1000)
  slug                  String                   @db.VarChar(191)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  specialty             Specialty                @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  @@unique([specialtyId, locale])
  @@unique([locale, slug])
  @@index([locale, title])
}

model PractitionerProfile {
  id                    String                   @id @default(uuid()) @db.Uuid
  userId                String                   @unique @db.Uuid
  countryId             String?                  @db.Uuid
  practitionerType      PractitionerType         @default(OTHER)
  publicSlug            String                   @unique @db.VarChar(191)
  professionalTitle     String?                  @db.VarChar(191)
  bio                   String?                  @db.VarChar(4000)
  yearsOfExperience     Int?
  sessionPrice30        Decimal?                 @db.Decimal(18, 2)
  sessionPrice60        Decimal?                 @db.Decimal(18, 2)
  avatarUrl             String?                  @db.VarChar(500)
  coverImageUrl         String?                  @db.VarChar(500)
  status                PractitionerStatus       @default(DRAFT)
  isOnlineToggleEnabled Boolean                  @default(false)
  isInstantBookingEnabled Boolean                @default(false)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  user                  User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  country               Country?                 @relation(fields: [countryId], references: [id], onDelete: SetNull)

  languages             PractitionerProfileLanguage[]
  specialties           PractitionerSpecialty[]
  applications          PractitionerApplication[]
  credentials           PractitionerCredential[]
  availabilitySlots     AvailabilitySlot[]
  availabilityExceptions AvailabilityException[]
  presence              PractitionerPresence?
  sessions              Session[]
  instantBookingRequests InstantBookingRequest[]
  payments              Payment[]
  wallets               PractitionerWallet[]
  ledgerEntries         LedgerEntry[]
  settlements           PractitionerSettlement[]
  coupons               Coupon[]
  articles              Article[]                @relation("ArticleAuthorPractitioner")
  conversations         Conversation[]           @relation("ConversationPractitioner")
  supportTickets        SupportTicket[]          @relation("SupportTicketPractitioner")
  chatApprovalRequests  ChatApprovalRequest[]
  couponRedemptions     CouponRedemption[]
  sessionReviews        SessionReview[]
  ratingSummary         PractitionerRatingSummary?
  coursesAsInstructor   TrainingInstructor[]

  @@index([status, practitionerType])
  @@index([countryId, status])
}

model PractitionerProfileLanguage {
  id                    String                   @id @default(uuid()) @db.Uuid
  practitionerId        String                   @db.Uuid
  languageId            String                   @db.Uuid
  isPrimary             Boolean                  @default(false)
  createdAt             DateTime                 @default(now())

  practitioner          PractitionerProfile      @relation(fields: [practitionerId], references: [id], onDelete: Cascade)
  language              Language                 @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@unique([practitionerId, languageId])
  @@index([languageId])
}

model PractitionerSpecialty {
  id                    String                   @id @default(uuid()) @db.Uuid
  practitionerId        String                   @db.Uuid
  specialtyId           String                   @db.Uuid
  isPrimary             Boolean                  @default(false)
  createdAt             DateTime                 @default(now())

  practitioner          PractitionerProfile      @relation(fields: [practitionerId], references: [id], onDelete: Cascade)
  specialty             Specialty                @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  @@unique([practitionerId, specialtyId])
  @@index([specialtyId, practitionerId])
}

model PractitionerApplication {
  id                    String                   @id @default(uuid()) @db.Uuid
  practitionerId        String                   @db.Uuid
  status                PractitionerApplicationStatus @default(DRAFT)
  submittedAt           DateTime?
  reviewedAt            DateTime?
  reviewNotes           String?                  @db.VarChar(1000)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  practitioner          PractitionerProfile      @relation(fields: [practitionerId], references: [id], onDelete: Cascade)

  @@index([practitionerId, status])
}

model PractitionerCredential {
  id                    String                   @id @default(uuid()) @db.Uuid
  practitionerId        String                   @db.Uuid
  credentialType        CredentialType
  fileUrl               String                   @db.VarChar(500)
  reviewStatus          CredentialReviewStatus   @default(PENDING)
  expiresAt             DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  practitioner          PractitionerProfile      @relation(fields: [practitionerId], references: [id], onDelete: Cascade)

  @@index([practitionerId, reviewStatus])
  @@index([expiresAt])
}

//////////////////////////////
// Sessions / Availability / Presence
//////////////////////////////

model AvailabilitySlot {
  id                    String                   @id @default(uuid()) @db.Uuid
  practitionerId        String                   @db.Uuid
  weekday               AvailabilityWeekday
  startMinute           Int
  endMinute             Int
  sessionDurationMinutes Int
  slotType              SlotType                 @default(REGULAR)
  isEnabled             Boolean                  @default(true)
  instantBookingEnabled Boolean                  @default(false)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  practitioner          PractitionerProfile      @relation(fields: [practitionerId], references: [id], onDelete: Cascade)

  @@index([practitionerId, weekday])
  @@index([practitionerId, isEnabled])
  @@index([practitionerId, instantBookingEnabled])
}

model AvailabilityException {
  id                    String                   @id @default(uuid()) @db.Uuid
  practitionerId        String                   @db.Uuid
  exceptionDate         DateTime                 @db.Date
  startAtUtc            DateTime?
  endAtUtc              DateTime?
  exceptionType         AvailabilityExceptionType
  reason                String?                  @db.VarChar(500)
  isBlocking            Boolean                  @default(true)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  practitioner          PractitionerProfile      @relation(fields: [practitionerId], references: [id], onDelete: Cascade)

  @@index([practitionerId, exceptionDate])
  @@index([practitionerId, exceptionType])
}

model PractitionerPresence {
  id                    String                   @id @default(uuid()) @db.Uuid
  practitionerId        String                   @unique @db.Uuid
  presenceStatus        PresenceStatus           @default(OFFLINE)
  lastSeenAt            DateTime?
  heartbeatAt           DateTime?
  manualStatusEnabled   Boolean                  @default(true)
  instantBookingLiveEnabled Boolean              @default(false)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  practitioner          PractitionerProfile      @relation(fields: [practitionerId], references: [id], onDelete: Cascade)

  @@index([presenceStatus])
  @@index([instantBookingLiveEnabled])
}

model Session {
  id                    String                   @id @default(uuid()) @db.Uuid
  patientId             String                   @db.Uuid
  practitionerId        String                   @db.Uuid
  flowType              SessionFlowType
  sessionMode           SessionMode
  durationMinutes       Int
  status                SessionStatus            @default(DRAFT)

  requestedStartAt      DateTime?
  scheduledStartAt      DateTime?
  scheduledEndAt        DateTime?
  joinOpenAt            DateTime?
  expiresAt             DateTime?

  timezoneSnapshot      String?                  @db.VarChar(50)
  provider              SessionProvider          @default(NONE)
  providerRoomId        String?                  @db.VarChar(191)
  providerSessionRef    String?                  @db.VarChar(191)
  notesInternal         String?                  @db.VarChar(1000)

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  patient               PatientProfile           @relation(fields: [patientId], references: [id], onDelete: Restrict)
  practitioner          PractitionerProfile      @relation(fields: [practitionerId], references: [id], onDelete: Restrict)
  events                SessionEvent[]
  instantBookingRequest InstantBookingRequest?
  payments              Payment[]
  refunds               Refund[]
  conversations         Conversation[]
  chatApprovalRequests  ChatApprovalRequest[]
  reviews               SessionReview[]

  @@index([patientId, status])
  @@index([practitionerId, status])
  @@index([scheduledStartAt])
  @@index([scheduledEndAt])
  @@index([flowType, status])
  @@index([provider, providerRoomId])
}

model SessionEvent {
  id                    String                   @id @default(uuid()) @db.Uuid
  sessionId             String                   @db.Uuid
  eventType             SessionEventType
  actorUserId           String?                  @db.Uuid
  metadataJson          Json?
  createdAt             DateTime                 @default(now())

  session               Session                  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([eventType, createdAt])
}

model InstantBookingRequest {
  id                    String                   @id @default(uuid()) @db.Uuid
  patientId             String                   @db.Uuid
  practitionerId        String                   @db.Uuid
  linkedSessionId       String?                  @unique @db.Uuid

  requestedDurationMinutes Int
  preferredMode         SessionMode
  status                InstantBookingRequestStatus @default(PENDING)

  requestedAt           DateTime                 @default(now())
  expiresAt             DateTime
  respondedAt           DateTime?

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  patient               PatientProfile           @relation(fields: [patientId], references: [id], onDelete: Restrict)
  practitioner          PractitionerProfile      @relation(fields: [practitionerId], references: [id], onDelete: Restrict)
  linkedSession         Session?                 @relation(fields: [linkedSessionId], references: [id], onDelete: SetNull)

  @@index([patientId, status])
  @@index([practitionerId, status])
  @@index([requestedAt])
  @@index([expiresAt])
}

//////////////////////////////
// Finance
//////////////////////////////

model Payment {
  id                    String                   @id @default(uuid()) @db.Uuid
  sessionId             String?                  @db.Uuid
  patientId             String                   @db.Uuid
  practitionerId        String?                  @db.Uuid

  paymentPurpose        PaymentPurpose
  provider              PaymentProvider
  status                PaymentStatus            @default(CREATED)

  amountSubtotal        Decimal                  @db.Decimal(18, 2)
  amountDiscount        Decimal                  @default(0) @db.Decimal(18, 2)
  amountTotal           Decimal                  @db.Decimal(18, 2)
  currencyCode          String                   @db.VarChar(3)

  commissionRuleId      String?                  @db.Uuid
  commissionPlatformRatePercent Decimal?         @db.Decimal(5, 2)
  commissionPractitionerRatePercent Decimal?     @db.Decimal(5, 2)
  couponId              String?                  @db.Uuid
  couponCodeSnapshot    String?                  @db.VarChar(64)
  couponDiscountSnapshot Decimal?                @db.Decimal(18, 2)
  couponPlatformShareSnapshot Decimal?           @db.Decimal(5, 2)
  couponPractitionerShareSnapshot Decimal?       @db.Decimal(5, 2)

  providerPaymentRef    String?                  @db.VarChar(191)
  providerOrderRef      String?                  @db.VarChar(191)
  providerCustomerRef   String?                  @db.VarChar(191)

  initiatedAt           DateTime                 @default(now())
  authorizedAt          DateTime?
  capturedAt            DateTime?
  failedAt              DateTime?
  cancelledAt           DateTime?
  expiredAt             DateTime?

  metadataJson          Json?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  session               Session?                 @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  patient               PatientProfile           @relation(fields: [patientId], references: [id], onDelete: Restrict)
  practitioner          PractitionerProfile?     @relation(fields: [practitionerId], references: [id], onDelete: SetNull)
  commissionRule        CommissionRule?          @relation(fields: [commissionRuleId], references: [id], onDelete: SetNull)
  coupon                Coupon?                  @relation(fields: [couponId], references: [id], onDelete: SetNull)

  events                PaymentEvent[]
  refunds               Refund[]
  ledgerEntries         LedgerEntry[]
  couponRedemptions     CouponRedemption[]
  enrollments           Enrollment[]

  @@index([sessionId])
  @@index([patientId, status])
  @@index([practitionerId, status])
  @@index([provider, status, createdAt])
  @@index([currencyCode, status])
  @@unique([provider, providerPaymentRef], map: "uq_payment_provider_payment_ref")
}

model PaymentEvent {
  id                    String                   @id @default(uuid()) @db.Uuid
  paymentId             String                   @db.Uuid
  eventType             PaymentEventType
  providerEventRef      String?                  @db.VarChar(191)
  payloadJson           Json?
  createdAt             DateTime                 @default(now())

  payment               Payment                  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId, createdAt])
  @@index([eventType, createdAt])
}

model Refund {
  id                    String                   @id @default(uuid()) @db.Uuid
  paymentId             String                   @db.Uuid
  sessionId             String?                  @db.Uuid
  refundType            RefundType
  status                RefundStatus             @default(REQUESTED)
  refundReason          String?                  @db.VarChar(500)
  amount                Decimal                  @db.Decimal(18, 2)
  currencyCode          String                   @db.VarChar(3)
  providerRefundRef     String?                  @db.VarChar(191)
  requestedAt           DateTime                 @default(now())
  processedAt           DateTime?
  failedAt              DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  payment               Payment                  @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  session               Session?                 @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([paymentId, status])
  @@index([sessionId, status])
  @@index([requestedAt])
}

model LedgerEntry {
  id                    String                   @id @default(uuid()) @db.Uuid
  practitionerId        String?                  @db.Uuid
  sessionId             String?                  @db.Uuid
  paymentId             String?                  @db.Uuid
  settlementId          String?                  @db.Uuid

  entryType             LedgerEntryType
  direction             LedgerDirection
  amount                Decimal                  @db.Decimal(18, 2)
  currencyCode          String                   @db.VarChar(3)
  balanceBucket         WalletBalanceBucket      @default(PENDING)

  referenceType         String?                  @db.VarChar(100)
  referenceId           String?                  @db.VarChar(191)
  description           String?                  @db.VarChar(500)
  effectiveAt           DateTime                 @default(now())
  metadataJson          Json?

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  practitioner          PractitionerProfile?     @relation(fields: [practitionerId], references: [id], onDelete: SetNull)
  session               Session?                 @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  payment               Payment?                 @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  settlement            PractitionerSettlement?  @relation(fields: [settlementId], references: [id], onDelete: SetNull)

  @@index([practitionerId, effectiveAt])
  @@index([practitionerId, balanceBucket, effectiveAt])
  @@index([sessionId])
  @@index([paymentId])
  @@index([settlementId])
  @@index([entryType, effectiveAt])
  @@index([referenceType, referenceId])
}

model PractitionerWallet {
  id                    String                   @id @default(uuid()) @db.Uuid
  practitionerId        String                   @db.Uuid
  currencyCode          String                   @db.VarChar(3)

  availableBalance      Decimal                  @default(0) @db.Decimal(18, 2)
  pendingBalance        Decimal                  @default(0) @db.Decimal(18, 2)
  reservedBalance       Decimal                  @default(0) @db.Decimal(18, 2)

  lifetimeEarned        Decimal                  @default(0) @db.Decimal(18, 2)
  lifetimePaidOut       Decimal                  @default(0) @db.Decimal(18, 2)
  lastLedgerEntryAt     DateTime?

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  practitioner          PractitionerProfile      @relation(fields: [practitionerId], references: [id], onDelete: Cascade)
  settlements           PractitionerSettlement[]

  @@unique([practitionerId, currencyCode])
}

model SettlementBatch {
  id                    String                   @id @default(uuid()) @db.Uuid
  periodYear            Int
  periodMonth           Int
  currencyCode          String                   @db.VarChar(3)
  status                SettlementBatchStatus    @default(DRAFT)
  slug                  String                   @unique @db.VarChar(191)

  generatedAt           DateTime?
  finalizedAt           DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  settlements           PractitionerSettlement[]

  @@unique([periodYear, periodMonth, currencyCode])
  @@index([status, periodYear, periodMonth])
}

model PractitionerSettlement {
  id                    String                   @id @default(uuid()) @db.Uuid
  batchId               String                   @db.Uuid
  practitionerId        String                   @db.Uuid
  walletId              String?                  @db.Uuid

  amountGross           Decimal                  @db.Decimal(18, 2)
  amountAdjustments     Decimal                  @default(0) @db.Decimal(18, 2)
  amountNet             Decimal                  @db.Decimal(18, 2)
  currencyCode          String                   @db.VarChar(3)

  payoutMethodSnapshot  Json?
  externalPayoutRef     String?                  @db.VarChar(191)
  status                PractitionerSettlementStatus @default(DRAFT)

  paidAt                DateTime?
  failedAt              DateTime?
  notes                 String?                  @db.VarChar(500)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  batch                 SettlementBatch          @relation(fields: [batchId], references: [id], onDelete: Cascade)
  practitioner          PractitionerProfile      @relation(fields: [practitionerId], references: [id], onDelete: Restrict)
  wallet                PractitionerWallet?      @relation(fields: [walletId], references: [id], onDelete: SetNull)
  ledgerEntries         LedgerEntry[]

  @@unique([batchId, practitionerId])
  @@index([practitionerId, status])
  @@index([paidAt])
}

model CommissionRule {
  id                    String                   @id @default(uuid()) @db.Uuid
  slug                  String                   @unique @db.VarChar(191)
  ruleName              String                   @db.VarChar(191)
  ruleScope             CommissionRuleScope
  marketType            MarketType               @default(ANY)

  practitionerCountryId String?                  @db.Uuid
  patientCountryId      String?                  @db.Uuid
  sessionFlowType       SessionFlowType?
  sessionMode           SessionMode?
  specialtyId           String?                  @db.Uuid

  platformRatePercent   Decimal                  @db.Decimal(5, 2)
  practitionerRatePercent Decimal                @db.Decimal(5, 2)

  priority              Int                      @default(0)
  isDefault             Boolean                  @default(false)
  isActive              Boolean                  @default(true)

  startsAt              DateTime?
  endsAt                DateTime?

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  specialty             Specialty?               @relation(fields: [specialtyId], references: [id], onDelete: SetNull)
  payments              Payment[]

  @@index([isActive, isDefault])
  @@index([priority, startsAt, endsAt])
  @@index([practitionerCountryId, patientCountryId])
  @@index([sessionFlowType, sessionMode])
  @@index([specialtyId])
}

model Coupon {
  id                    String                   @id @default(uuid()) @db.Uuid
  code                  String                   @unique @db.VarChar(64)
  slug                  String                   @unique @db.VarChar(191)

  createdByUserId       String                   @db.Uuid
  ownerPractitionerId   String?                  @db.Uuid
  approvedByUserId      String?                  @db.Uuid

  couponScope           CouponScope
  status                CouponStatus             @default(DRAFT)
  discountType          DiscountType
  discountValue         Decimal                  @db.Decimal(18, 2)
  maxDiscountAmount     Decimal?                 @db.Decimal(18, 2)

  platformSharePercent  Decimal                  @db.Decimal(5, 2)
  practitionerSharePercent Decimal               @db.Decimal(5, 2)

  usageLimitTotal       Int?
  usageLimitPerPatient  Int?
  currentUsageCount     Int                      @default(0)

  requiresApproval      Boolean                  @default(true)
  approvedAt            DateTime?
  startsAt              DateTime?
  endsAt                DateTime?
  isActive              Boolean                  @default(false)

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  ownerPractitioner     PractitionerProfile?     @relation(fields: [ownerPractitionerId], references: [id], onDelete: SetNull)
  payments              Payment[]
  redemptions           CouponRedemption[]

  @@index([ownerPractitionerId, status])
  @@index([status, startsAt, endsAt])
  @@index([approvedByUserId])
}

model CouponRedemption {
  id                    String                   @id @default(uuid()) @db.Uuid
  couponId              String                   @db.Uuid
  sessionId             String?                  @db.Uuid
  paymentId             String?                  @db.Uuid
  patientId             String                   @db.Uuid
  practitionerId        String?                  @db.Uuid

  currencyCode          String                   @db.VarChar(3)
  grossAmount           Decimal                  @db.Decimal(18, 2)
  discountAmount        Decimal                  @db.Decimal(18, 2)
  platformDiscountShare Decimal                  @db.Decimal(18, 2)
  practitionerDiscountShare Decimal              @db.Decimal(18, 2)

  redeemedAt            DateTime                 @default(now())
  createdAt             DateTime                 @default(now())

  coupon                Coupon                   @relation(fields: [couponId], references: [id], onDelete: Restrict)
  session               Session?                 @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  payment               Payment?                 @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  patient               PatientProfile           @relation(fields: [patientId], references: [id], onDelete: Restrict)
  practitioner          PractitionerProfile?     @relation(fields: [practitionerId], references: [id], onDelete: SetNull)

  @@unique([couponId, sessionId], map: "uq_coupon_redemption_coupon_session")
  @@index([patientId, redeemedAt])
  @@index([practitionerId, redeemedAt])
  @@index([paymentId])
}

//////////////////////////////
// Articles / Content
//////////////////////////////

model ArticleCategory {
  id                    String                   @id @default(uuid()) @db.Uuid
  parentId              String?                  @db.Uuid
  slugRoot              String                   @unique @db.VarChar(191)
  sortOrder             Int                      @default(0)
  isActive              Boolean                  @default(true)
  isFeatured            Boolean                  @default(false)
  createdByUserId       String?                  @db.Uuid
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  parent                ArticleCategory?         @relation("ArticleCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children              ArticleCategory[]        @relation("ArticleCategoryTree")
  translations          ArticleCategoryTranslation[]
  primaryArticles       Article[]                @relation("ArticlePrimaryCategory")
  assignments           ArticleCategoryAssignment[]

  @@index([isActive, sortOrder])
  @@index([parentId, sortOrder])
}

model ArticleCategoryTranslation {
  id                    String                   @id @default(uuid()) @db.Uuid
  articleCategoryId     String                   @db.Uuid
  locale                ContentLocale
  title                 String                   @db.VarChar(191)
  description           String?                  @db.VarChar(500)
  slug                  String                   @db.VarChar(191)
  metaTitle             String?                  @db.VarChar(191)
  metaDescription       String?                  @db.VarChar(300)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  articleCategory       ArticleCategory          @relation(fields: [articleCategoryId], references: [id], onDelete: Cascade)

  @@unique([locale, slug])
  @@unique([articleCategoryId, locale])
  @@index([locale, title])
}

model Article {
  id                    String                   @id @default(uuid()) @db.Uuid
  authorUserId          String                   @db.Uuid
  authorPractitionerId  String?                  @db.Uuid
  primaryCategoryId     String?                  @db.Uuid

  status                ArticleStatus            @default(DRAFT)
  visibility            ArticleVisibility        @default(PUBLIC)

  coverImageUrl         String?                  @db.VarChar(500)
  featuredImageAlt      String?                  @db.VarChar(191)
  currentRevisionNumber Int                      @default(1)

  lastSubmittedAt       DateTime?
  approvedAt            DateTime?
  rejectedAt            DateTime?
  publishedAt           DateTime?
  scheduledPublishAt    DateTime?
  archivedAt            DateTime?

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  authorUser            User                     @relation("ArticleAuthorUser", fields: [authorUserId], references: [id], onDelete: Restrict)
  authorPractitioner    PractitionerProfile?     @relation("ArticleAuthorPractitioner", fields: [authorPractitionerId], references: [id], onDelete: SetNull)
  primaryCategory       ArticleCategory?         @relation("ArticlePrimaryCategory", fields: [primaryCategoryId], references: [id], onDelete: SetNull)

  translations          ArticleTranslation[]
  categoryAssignments   ArticleCategoryAssignment[]
  reviews               ArticleReview[]
  moderationLogs        ArticleModerationLog[]
  tagAssignments        ArticleTagAssignment[]

  @@index([status, publishedAt])
  @@index([primaryCategoryId, status, publishedAt])
  @@index([authorUserId, status])
  @@index([authorPractitionerId, status])
  @@index([visibility, status, publishedAt])
  @@index([scheduledPublishAt])
  @@index([approvedAt])
}

model ArticleTranslation {
  id                    String                   @id @default(uuid()) @db.Uuid
  articleId             String                   @db.Uuid
  locale                ContentLocale
  title                 String                   @db.VarChar(191)
  excerpt               String?                  @db.VarChar(1000)
  contentMarkdown       String?
  slug                  String                   @db.VarChar(191)
  metaTitle             String?                  @db.VarChar(191)
  metaDescription       String?                  @db.VarChar(300)
  readingTimeMinutes    Int?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  article               Article                  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([locale, slug])
  @@unique([articleId, locale])
  @@index([locale, title])
}

model ArticleCategoryAssignment {
  id                    String                   @id @default(uuid()) @db.Uuid
  articleId             String                   @db.Uuid
  articleCategoryId     String                   @db.Uuid
  isPrimary             Boolean                  @default(false)
  createdAt             DateTime                 @default(now())

  article               Article                  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleCategory       ArticleCategory          @relation(fields: [articleCategoryId], references: [id], onDelete: Cascade)

  @@unique([articleId, articleCategoryId])
  @@index([articleCategoryId, articleId])
}

model ArticleReview {
  id                    String                   @id @default(uuid()) @db.Uuid
  articleId             String                   @db.Uuid
  reviewerUserId        String                   @db.Uuid
  reviewStatus          ReviewStatus
  reviewNote            String?                  @db.VarChar(1000)
  internalNote          String?                  @db.VarChar(1000)
  createdAt             DateTime                 @default(now())

  article               Article                  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId, createdAt])
  @@index([reviewerUserId, createdAt])
  @@index([reviewStatus, createdAt])
}

model ArticleModerationLog {
  id                    String                   @id @default(uuid()) @db.Uuid
  articleId             String                   @db.Uuid
  actorUserId           String?                  @db.Uuid
  eventType             ModerationEventType
  note                  String?                  @db.VarChar(1000)
  metadataJson          Json?
  createdAt             DateTime                 @default(now())

  article               Article                  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([eventType, createdAt])
}

model ArticleTag {
  id                    String                   @id @default(uuid()) @db.Uuid
  slugRoot              String                   @unique @db.VarChar(191)
  sortOrder             Int                      @default(0)
  isActive              Boolean                  @default(true)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  translations          ArticleTagTranslation[]
  assignments           ArticleTagAssignment[]

  @@index([isActive, sortOrder])
}

model ArticleTagTranslation {
  id                    String                   @id @default(uuid()) @db.Uuid
  articleTagId          String                   @db.Uuid
  locale                ContentLocale
  title                 String                   @db.VarChar(191)
  slug                  String                   @db.VarChar(191)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  articleTag            ArticleTag               @relation(fields: [articleTagId], references: [id], onDelete: Cascade)

  @@unique([locale, slug])
  @@unique([articleTagId, locale])
  @@index([locale, title])
}

model ArticleTagAssignment {
  id                    String                   @id @default(uuid()) @db.Uuid
  articleId             String                   @db.Uuid
  articleTagId          String                   @db.Uuid
  createdAt             DateTime                 @default(now())

  article               Article                  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleTag            ArticleTag               @relation(fields: [articleTagId], references: [id], onDelete: Cascade)

  @@unique([articleId, articleTagId])
  @@index([articleTagId, articleId])
}

//////////////////////////////
// Chat / Support / Moderation
//////////////////////////////

model Conversation {
  id                    String                   @id @default(uuid()) @db.Uuid
  conversationType      ConversationType
  status                ConversationStatus       @default(OPEN)

  patientId             String?                  @db.Uuid
  practitionerId        String?                  @db.Uuid
  supportTicketId       String?                  @unique @db.Uuid
  sessionId             String?                  @db.Uuid
  chatApprovalRequestId String?                  @unique @db.Uuid

  conversationRef       String?                  @unique @db.VarChar(64)

  startedAt             DateTime                 @default(now())
  closedAt              DateTime?
  expiresAt             DateTime?

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  patient               PatientProfile?          @relation("ConversationPatient", fields: [patientId], references: [id], onDelete: SetNull)
  practitioner          PractitionerProfile?     @relation("ConversationPractitioner", fields: [practitionerId], references: [id], onDelete: SetNull)
  session               Session?                 @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  participants          ConversationParticipant[]
  messages              Message[]
  internalNotes         InternalConversationNote[]
  moderationReports     ChatModerationReport[]
  moderationActions     ChatModerationAction[]
  supportTicket         SupportTicket?
  chatApprovalRequest   ChatApprovalRequest?

  @@index([conversationType, status, startedAt])
  @@index([patientId, status])
  @@index([practitionerId, status])
  @@index([supportTicketId])
  @@index([chatApprovalRequestId])
  @@index([sessionId])
}

model ConversationParticipant {
  id                    String                   @id @default(uuid()) @db.Uuid
  conversationId        String                   @db.Uuid
  userId                String                   @db.Uuid
  participantRole       ConversationParticipantRole
  joinedAt              DateTime                 @default(now())
  leftAt                DateTime?
  lastReadMessageId     String?                  @db.Uuid
  lastReadAt            DateTime?
  isMuted               Boolean                  @default(false)
  isActive              Boolean                  @default(true)

  conversation          Conversation             @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId, isActive])
  @@index([conversationId, participantRole])
}

model Message {
  id                    String                   @id @default(uuid()) @db.Uuid
  conversationId        String                   @db.Uuid
  senderUserId          String?                  @db.Uuid
  messageType           MessageType              @default(TEXT)
  status                MessageStatus            @default(SENT)
  visibility            MessageVisibility        @default(NORMAL)

  contentText           String?
  replyToMessageId      String?                  @db.Uuid

  sentAt                DateTime                 @default(now())
  deliveredAt           DateTime?
  readAt                DateTime?
  editedAt              DateTime?
  deletedAt             DateTime?
  isFlagged             Boolean                  @default(false)

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  conversation          Conversation             @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  replyToMessage        Message?                 @relation("MessageReplies", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies               Message[]                @relation("MessageReplies")
  attachments           MessageAttachment[]
  moderationReports     ChatModerationReport[]
  moderationActions     ChatModerationAction[]

  @@index([conversationId, sentAt])
  @@index([senderUserId, sentAt])
  @@index([replyToMessageId])
  @@index([status, sentAt])
  @@index([isFlagged, sentAt])
}

model MessageAttachment {
