# ==============================================================================
# Fayed Backend v1 - Environment Configuration
# Copy this file to .env and fill in real values.
# Never commit real secrets.
# ==============================================================================

# App
APP_ENV=development
NODE_ENV=development
PORT=6001
APP_NAME=fayed-backend-v1
APP_URL=http://localhost:6001
APP_BASE_URL=http://localhost:3000
APP_DEFAULT_LOCALE=ar
# Tip (LAN dev): you can set `CORS_ORIGINS=*` in non-production to allow any origin.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8081,http://127.0.0.1:8081,http://localhost:6001,http://127.0.0.1:6001
CONFIG_HTTP_ENABLED=false
CONFIG_HTTP_TOKEN=
LOG_LEVEL=debug
LOG_PRETTY=true
LOG_HTTP_ENABLED=true

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/fayed_db

# JWT
JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=fayed-backend-v1
AUTH_PASSWORD_SALT_ROUNDS=12
AUTH_OTP_CODE_LENGTH=6
AUTH_LOGIN_OTP_TTL_MINUTES=10
AUTH_RESET_PASSWORD_TTL_MINUTES=15
AUTH_OTP_MAX_ATTEMPTS=5
AUTH_OTP_RESEND_COOLDOWN_SECONDS=30

# Google Auth
GOOGLE_CLIENT_ID=29096062638-4h4rtv9i3snl5jr7ni6phku7qrojlbua.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:6001/api/v1/auth/google/callback

# Email / SMS
MAIL_PROVIDER=sendgrid
MAIL_FROM=noreply@fayed.app
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_SECURE=false
DEV_OTP_EMAIL_REDIRECT=
DEV_OTP_BYPASS_DELIVERY_FAILURES=false
SMS_PROVIDER=twilio

# Video
DAILY_API_KEY=your_daily_api_key
DAILY_WEBHOOK_SECRET=
ZOOM_ACCOUNT_ID=your_zoom_account_id
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret

# Session booking
SESSION_PAYMENT_RESERVATION_MINUTES=15

# Payment redirect URLs (frontend)
PAYMENT_SUCCESS_URL=http://localhost:3000/payment/success
PAYMENT_FAILED_URL=http://localhost:3000/payment/failed
PAYMENT_PENDING_URL=http://localhost:3000/payment/pending

# Payments - Stripe
PAYMENT_STRIPE_ENABLED=false
STRIPE_MODE=test
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxx
STRIPE_API_BASE_URL=https://api.stripe.com

# Payments - Paymob
PAYMENT_PAYMOB_ENABLED=false
PAYMOB_MODE=test
PAYMOB_API_KEY=xxxxxxxxx
PAYMOB_INTEGRATION_ID_CARD=xxxxx
PAYMOB_INTEGRATION_ID_WALLET=
PAYMOB_IFRAME_ID=xxxxx
PAYMOB_HMAC_SECRET=xxxxxxxxx
PAYMOB_BASE_URL=https://accept.paymob.com/api

# Legacy compatibility (optional; deprecated in favor of *_CARD)
PAYMOB_INTEGRATION_ID=
