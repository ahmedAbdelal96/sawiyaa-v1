# ==============================================================================
# Sawiyaa Backend v1 - Environment Configuration
# Copy this file to .env and fill in real values.
# Never commit real secrets.
# ==============================================================================

# App
APP_ENV=development
NODE_ENV=development
PORT=6001
APP_NAME=sawiyaa-backend-v1
APP_URL=http://localhost:6001
APP_BASE_URL=http://localhost:3000
APP_DEFAULT_LOCALE=ar
# Tip (LAN dev): you can set `CORS_ORIGINS=*` in non-production to allow any origin.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8081,http://127.0.0.1:8081,http://localhost:6001,http://127.0.0.1:6001
CONFIG_HTTP_ENABLED=false
CONFIG_HTTP_TOKEN=
LOG_LEVEL=debug
LOG_PRETTY=true
LOG_HTTP_ENABLED=true

# Throttling / Rate limiting
# IMPORTANT: memory store is NOT multi-instance safe.
THROTTLE_STORE=memory
# Required only when THROTTLE_STORE=redis
REDIS_URL=redis://localhost:6379
THROTTLE_KEY_PREFIX=fayed:throttle
# Optional: hashes throttle keys to avoid storing raw emails/phones in Redis keys.
THROTTLE_KEY_HASH_SECRET=

# Step-up (re-auth) for sensitive admin/finance actions
# Default behavior: enabled in production, disabled elsewhere unless explicitly set.
STEP_UP_ENABLED=false
STEP_UP_TTL_SECONDS=600

# Accounting reconciliation operations
ACCOUNTING_RECONCILIATION_ENABLED=false
ACCOUNTING_RECONCILIATION_LOOKBACK_DAYS=7
ACCOUNTING_RECONCILIATION_BATCH_SIZE=100
ACCOUNTING_RECONCILIATION_CRON=0 3 * * *
ACCOUNTING_RECONCILIATION_ALERTS_ENABLED=false

# Care Chat Expiry Sweeper
# This is a low-frequency cleanup job that expires pending care-chat approval requests
# after their expiresAt time has passed.
#
# Production recommendation:
# - Keep this slow. Do NOT run it every minute or every hour.
# - Default initial delay after app bootstrap: 3 minutes.
# - Default interval: 24 hours.
# - The job should only update PENDING requests where expiresAt <= now.
# - It must never block app startup.
# - It should use batch updates and avoid loading unnecessary relations.
#
# Current defaults are intentionally conservative:
# CARE_CHAT_EXPIRY_SWEEPER_INITIAL_DELAY_MS=180000
# CARE_CHAT_EXPIRY_SWEEPER_INTERVAL_MS=86400000

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/fayed_db

# JWT
JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=fayed-backend-v1
AUTH_PASSWORD_SALT_ROUNDS=12
AUTH_OTP_CODE_LENGTH=6
AUTH_LOGIN_OTP_TTL_MINUTES=10
AUTH_RESET_PASSWORD_TTL_MINUTES=15
AUTH_OTP_MAX_ATTEMPTS=5
AUTH_OTP_RESEND_COOLDOWN_SECONDS=30
AUTH_COOKIE_AUTH_ENABLED=false
AUTH_CSRF_ENFORCEMENT_ENABLED=false
AUTH_CSRF_COOKIE_NAME=fayed_csrf_token
AUTH_CSRF_HEADER_NAME=x-csrf-token
# Practitioner login OTP feature toggle (primary source of truth).
# true  = require OTP after password login (never overridden).
# false = emergency bypass; password login issues tokens directly.
# unset = fall back to legacy AUTH_PRACTITIONER_LOGIN_OTP_BYPASS_IN_DEV
#         in development only.
# Useful as a temporary switch when email/OTP delivery has an outage.
AUTH_PRACTITIONER_LOGIN_OTP_ENABLED=true

# Legacy development-only bypass.
# Used only when AUTH_PRACTITIONER_LOGIN_OTP_ENABLED is unset
# AND NODE_ENV=development. Has NO effect when the new flag is
# explicitly set to 'true' or 'false'.
AUTH_PRACTITIONER_LOGIN_OTP_BYPASS_IN_DEV=false

# Google Auth
GOOGLE_CLIENT_ID=29096062638-4h4rtv9i3snl5jr7ni6phku7qrojlbua.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:6001/api/v1/auth/google/callback

# Email / SMS
# MAIL_PROVIDER can be "smtp" or "brevo". SMTP is the default.
# When set to "brevo", BREVO_API_KEY must also be provided.
MAIL_PROVIDER=smtp
MAIL_FROM=noreply@sawiyaa.app
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_SECURE=false
DEV_OTP_EMAIL_REDIRECT=
DEV_OTP_BYPASS_DELIVERY_FAILURES=false
# Brevo (Sendinblue) transactional email — only used when MAIL_PROVIDER=brevo
# BREVO_API_KEY is required when MAIL_PROVIDER=brevo
BREVO_API_KEY=
# BREVO_API_URL is optional and defaults to https://api.brevo.com
BREVO_API_URL=https://api.brevo.com
SMS_PROVIDER=twilio

# Video
DAILY_API_KEY=your_daily_api_key
DAILY_API_BASE_URL=https://api.daily.co/v1
DAILY_WEBHOOK_SECRET=

# Session booking
SESSION_PAYMENT_RESERVATION_MINUTES=15

# Payment redirect URLs (frontend)
PAYMENT_SUCCESS_URL=http://localhost:3000/payment/success
PAYMENT_FAILED_URL=http://localhost:3000/payment/failed
PAYMENT_PENDING_URL=http://localhost:3000/payment/pending

# Payments - Stripe
PAYMENT_STRIPE_ENABLED=false
STRIPE_MODE=test
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxx
STRIPE_API_BASE_URL=https://api.stripe.com

# Payments - Paymob
PAYMENT_PAYMOB_ENABLED=false
PAYMOB_MODE=test
PAYMOB_API_KEY=xxxxxxxxx
# Explicit currency-aware method config for new checkout flows
PAYMOB_EGP_CARD_INTEGRATION_ID=
PAYMOB_EGP_WALLET_INTEGRATION_ID=
PAYMOB_USD_CARD_INTEGRATION_ID=
PAYMOB_IFRAME_ID=xxxxx
PAYMOB_DEFAULT_CHECKOUT_METHOD=CARD
PAYMOB_HMAC_SECRET=xxxxxxxxx
PAYMOB_BASE_URL=https://accept.paymob.com/api
PAYMOB_INTENTION_BASE_URL=https://flashapi.paymob.com
PAYMOB_CHECKOUT_BASE_URL=https://flashapi.paymob.com
PAYMOB_CHECKOUT_FLOW=legacy
# Structured alternative to the explicit env vars above.
# If used, each enabled method must declare explicit currencyCodes.
# Do not configure USD WALLET.
PAYMOB_METHOD_REGISTRY_JSON=

# Legacy compatibility (optional; deprecated, maps to EGP CARD only)
PAYMOB_INTEGRATION_ID=
PAYMOB_INTEGRATION_ID_CARD=
PAYMOB_INTEGRATION_ID_WALLET=
