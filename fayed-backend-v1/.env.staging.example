# Standardized package staging example
# Copy into the approved staging secret store or deploy env, then fill in real staging values there.

# Core app/runtime
APP_ENV=staging
NODE_ENV=production
APP_NAME=fayed
APP_URL=https://staging-api.example.com
APP_BASE_URL=https://staging.example.com
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<db>?schema=public
CORS_ORIGINS=https://staging.example.com,https://admin-staging.example.com

# Payment redirects
PAYMENT_SUCCESS_URL=https://staging.example.com/payment/success
PAYMENT_FAILED_URL=https://staging.example.com/payment/failed
PAYMENT_PENDING_URL=https://staging.example.com/payment/pending

# Stripe sandbox / test mode
PAYMENT_STRIPE_ENABLED=false
STRIPE_MODE=test
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_BASE_URL=https://api.stripe.com

# Paymob sandbox / test mode
PAYMENT_PAYMOB_ENABLED=true
PAYMOB_MODE=test
PAYMOB_API_KEY=
PAYMOB_PUBLIC_KEY=
PAYMOB_HMAC_SECRET=
PAYMOB_INTEGRATION_ID=
PAYMOB_INTEGRATION_ID_CARD=
PAYMOB_INTEGRATION_ID_WALLET=
PAYMOB_IFRAME_ID=
PAYMOB_BASE_URL=https://accept.paymob.com/api
PAYMOB_INTENTION_BASE_URL=https://flashapi.paymob.com
PAYMOB_CHECKOUT_BASE_URL=https://flashapi.paymob.com
PAYMOB_CHECKOUT_FLOW=legacy
PAYMOB_DEFAULT_CHECKOUT_METHOD=
PAYMOB_METHOD_REGISTRY_JSON=

# Session timing / hold behavior
SESSION_PAYMENT_RESERVATION_MINUTES=15
SESSION_JOIN_LEAD_MINUTES=10
SESSION_JOIN_LAG_MINUTES=15
SESSION_RUNTIME_PREPARE_LEAD_MINUTES=15

# Optional notification transport
MAIL_PROVIDER=mailtrap
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@example.com

# Optional operational settings
LOG_LEVEL=info
LOG_PRETTY=false
CONFIG_HTTP_ENABLED=false
CONFIG_HTTP_TOKEN=

# Notes:
# - Use sandbox credentials only.
# - Do not commit real values into the repository.
# - Test accounts are staging data, not env vars.
