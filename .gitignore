# Monorepo-wide ignores

# Dependencies
**/node_modules/
**/.pnp
**/.pnp.js

# Build outputs
**/dist/
**/build/
**/out/
**/.next/
**/coverage/
**/.nyc_output/

# Local env files (never commit secrets)
**/.env
**/.env.*
!**/.env.example
!**/.env.*.example

# Logs & temp
**/logs/
**/*.log
**/*.err.log
**/.tmp/
**/.temp/
**/tmp_*

# Editor/OS
**/.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
**/.DS_Store
**/Thumbs.db

# Archives / exports
*.zip
*.7z
*.rar

# Local backups (do not commit)
git-subrepos-backup/

# Backend runtime storage (can contain user uploads / sensitive data)
fayed-backend-v1/storage/**
!fayed-backend-v1/storage/.gitkeep
!fayed-backend-v1/storage/**/.gitkeep

# Local screenshot exports (optional artifacts)
WhatsApp Image *.jpg
WhatsApp Image *.jpeg
patient_mobile_app_screen/whatsapp_image_*

# Generated QA / smoke artifacts
**/artifacts/
**/*artifacts*/
**/smokes/
**/tmp/
**/*.tmp*

# Generated screenshot files used during debugging
admin-*.png
smoke-*.png
signin*.png
post-login.png
tmp-*.png
tmp-*.exe

# Local upload/runtime folders
fayed-backend-v1/uploads/
