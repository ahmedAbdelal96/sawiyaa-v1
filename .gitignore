# Monorepo-wide ignores

# Dependencies
**/node_modules/
**/.pnp
**/.pnp.js

# Build outputs
**/dist/
**/build/
**/out/
**/.next/
**/coverage/
**/.nyc_output/
dist/
build/
.next/
coverage/

# Local env files (never commit secrets)
**/.env
**/.env.*
!**/.env.example
!**/.env.*.example
.env
.env.*
!.env.example

# Logs & temp
**/logs/
**/*.log
**/*.err.log
logs/
*.log
*.tsbuildinfo
**/.tmp/
**/.temp/
**/tmp_*
tmp/
cache/
.cache/
test-reports/
reports/
check-articles*.ts
check-counts.js
fix-arabic*.py
run-articles-only.ts

# Editor/OS
**/.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
**/.DS_Store
**/Thumbs.db

# Archives / exports
*.zip
*.7z
*.rar

# Local backups (do not commit)
git-subrepos-backup/

# Backend runtime storage (can contain user uploads / sensitive data)
fayed-backend-v1/storage/**
!fayed-backend-v1/storage/.gitkeep
!fayed-backend-v1/storage/**/.gitkeep

# Local screenshot exports (optional artifacts)
WhatsApp Image *.jpg
WhatsApp Image *.jpeg
patient_mobile_app_screen/whatsapp_image_*

# Generated QA / smoke artifacts
**/artifacts/
**/*artifacts*/
**/smokes/
**/tmp/
**/*.tmp*

# Test screenshots and test artifacts
**/test-results/
**/test-results/**
**/test/
**/test/*.png
**/test/*.html

# Generated screenshot files used during debugging
admin-*.png
smoke-*.png
signin*.png
post-login.png
tmp-*.png
tmp-*.exe
qa_*.png
.tmp_*.png

# Local upload/runtime folders
fayed-backend-v1/uploads/

# Local AI/tooling folders
.agents/
.claude/
.codex/
.cursor/
.gemini/
.kiro/
.opencode/
.qodo/
.qoder/
.rovodev/
.trae/
.trae-cn/

# Local app/browser artifacts
.artifacts/
artifacts/
tmp/
smokes/
stitch_*/
button-list.json
.tmp-generate-matrices.js
fayed-frontend-v3/

# External reference apps
shezlong/
