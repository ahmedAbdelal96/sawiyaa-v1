{
  "expo": {
    "name": "Fayed",
    "slug": "fayed-mobile",
    "scheme": "fayed",
    "description": "A mobile care platform for patients and practitioners.",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fayed.mobile",
      "buildNumber": "1.0.0"
    },
    "android": {
      "package": "com.fayed.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router", "expo-localization", "expo-notifications"]
  }
}
